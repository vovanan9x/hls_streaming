<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập — HLS Streaming</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/style.css">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg-primary);
      overflow: hidden;
    }

    /* Animated blobs */
    .login-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.12;
      animation: blobFloat 8s ease-in-out infinite;
    }
    .blob-1 {
      width: 420px; height: 420px;
      background: radial-gradient(circle, #8b5cf6, #6d28d9);
      top: -120px; left: -100px;
      animation-delay: 0s;
    }
    .blob-2 {
      width: 320px; height: 320px;
      background: radial-gradient(circle, #3b82f6, #1d4ed8);
      bottom: -80px; right: -80px;
      animation-delay: 3s;
    }
    .blob-3 {
      width: 240px; height: 240px;
      background: radial-gradient(circle, #c084fc, #8b5cf6);
      top: 40%; right: 10%;
      animation-delay: 6s;
    }
    @keyframes blobFloat {
      0%, 100% { transform: translate(0,0) scale(1); }
      33%       { transform: translate(20px, -20px) scale(1.05); }
      66%       { transform: translate(-15px, 15px) scale(0.95); }
    }

    .login-container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 400px;
      padding: 20px;
    }

    .login-card {
      background: rgba(18, 18, 31, 0.85);
      border: 1px solid rgba(139,92,246,0.2);
      border-radius: var(--radius-xl);
      padding: 40px 36px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(139,92,246,0.08);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
    }

    .login-logo {
      text-align: center;
      margin-bottom: 36px;
    }

    .login-logo-icon {
      width: 56px; height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 14px;
      box-shadow: 0 8px 24px rgba(139,92,246,0.4);
    }
    .login-logo-icon svg { width: 28px; height: 28px; color: #fff; }

    .login-logo-text {
      font-size: 22px;
      font-weight: 750;
      background: linear-gradient(135deg, #e2d9fa, #c4b5fd, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.5px;
    }

    .login-logo-sub {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .input-wrap {
      position: relative;
    }
    .input-wrap svg {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      width: 16px; height: 16px; color: var(--text-muted);
      pointer-events: none;
    }
    .input-wrap input {
      padding-left: 40px;
      height: 46px;
      font-size: 14.5px;
    }
    .input-wrap input:focus + .input-icon { color: var(--accent); }

    .login-submit {
      width: 100%;
      padding: 13px;
      font-size: 14.5px;
      justify-content: center;
      margin-top: 4px;
      border-radius: var(--radius-sm);
      letter-spacing: 0.2px;
    }
  </style>
</head>
<body>

  <!-- Background blobs -->
  <div class="login-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="login-container">
    <div class="login-card">

      <!-- Logo -->
      <div class="login-logo">
        <div class="login-logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
        </div>
        <div class="login-logo-text">HLS Stream</div>
        <div class="login-logo-sub">Admin Panel · Secure Login</div>
      </div>

      <!-- Error -->
      <% if (error) { %>
        <div class="alert alert-error" style="margin-bottom:22px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <%= error %>
        </div>
      <% } %>

      <!-- Form -->
      <form action="/auth/login" method="POST">
        <div class="form-group">
          <label class="form-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            Tên đăng nhập
          </label>
          <div class="input-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            <input type="text" name="username" class="form-input" placeholder="Nhập username..." required autofocus>
          </div>
        </div>

        <div class="form-group" style="margin-bottom:24px;">
          <label class="form-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Mật khẩu
          </label>
          <div class="input-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input type="password" name="password" class="form-input" placeholder="Nhập mật khẩu..." required>
          </div>
        </div>

        <button type="submit" class="btn btn-primary login-submit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Đăng nhập
        </button>
      </form>

    </div>
  </div>

</body>
</html>