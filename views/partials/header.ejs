<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'Admin' %> — HLS Streaming
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <span class="logo-icon">🎬</span>
                    <span class="logo-text">HLS Stream</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <a href="/admin/home"
                    class="nav-item<%= typeof title !== 'undefined' && title === 'Tổng quan' ? ' active' : '' %>">
                    <span class="nav-icon">🏠</span>
                    <span>Tổng quan</span>
                </a>
                <a href="/admin/upload"
                    class="nav-item<%= typeof title !== 'undefined' && title === 'Upload Video' ? ' active' : '' %>">
                    <span class="nav-icon">📤</span>
                    <span>Upload Video</span>
                </a>
                <a href="/admin/videos"
                    class="nav-item<%= typeof title !== 'undefined' && title === 'Quản lí Video' ? ' active' : '' %>">
                    <span class="nav-icon">🎞️</span>
                    <span>Quản lí Video</span>
                </a>
                <% if (typeof currentUser !=='undefined' && currentUser && currentUser.role==='administrator' ) { %>
                    <a href="/admin/servers"
                        class="nav-item<%= typeof title !== 'undefined' && title === 'Quản lí Server' ? ' active' : '' %>">
                        <span class="nav-icon">🖥️</span>
                        <span>Quản lí Server</span>
                    </a>
                    <a href="/admin/users"
                        class="nav-item<%= typeof title !== 'undefined' && title === 'Quản lí Tài khoản' ? ' active' : '' %>">
                        <span class="nav-icon">👥</span>
                        <span>Tài khoản</span>
                    </a>
                    <a href="/admin/delete-requests"
                        class="nav-item<%= typeof title !== 'undefined' && title === 'Yêu cầu Xoá Video' ? ' active' : '' %>"
                        style="position:relative;">
                        <span class="nav-icon">🗑️</span>
                        <span>Yêu cầu Xoá</span>
                        <% if (typeof pendingDeleteCount !=='undefined' && pendingDeleteCount> 0) { %>
                            <span
                                style="position:absolute;top:6px;right:10px;min-width:18px;height:18px;padding:0 5px;border-radius:9px;background:var(--danger);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;line-height:1;">
                                <%= pendingDeleteCount %>
                            </span>
                            <% } %>
                    </a>
                    <% } %>
                        <a href="/admin/analytics"
                            class="nav-item<%= typeof title !== 'undefined' && title === 'Thống kê' ? ' active' : '' %>">
                            <span class="nav-icon">📊</span><span>Thống kê</span>
                        </a>
                        <% if (typeof currentUser !=='undefined' && currentUser && currentUser.role==='administrator' )
                            { %>
                            <a href="/admin/settings"
                                class="nav-item<%= typeof title !== 'undefined' && title === 'Cài đặt Hệ thống' ? ' active' : '' %>">
                                <span class="nav-icon">⚙️</span><span>Cài đặt</span>
                            </a>
                            <a href="/admin/api-docs"
                                class="nav-item<%= typeof title !== 'undefined' && title === 'API Documentation' ? ' active' : '' %>">
                                <span class="nav-icon">📡</span><span>API Docs</span>
                            </a>
                            <a href="/admin/errors"
                                class="nav-item<%= typeof title !== 'undefined' && title === 'Nhật ký Lỗi' ? ' active' : '' %>">
                                <span class="nav-icon">🚨</span><span>Nhật ký Lỗi</span>
                            </a>
                            <a href="/admin/workers"
                                class="nav-item<%= typeof title !== 'undefined' && title === 'Encode Workers' ? ' active' : '' %>">
                                <span class="nav-icon">🔧</span><span>Encode Workers</span>
                            </a>
                            <a href="/admin/cdn"
                                class="nav-item<%= typeof title !== 'undefined' && title === 'CDN Domains (CF Pool)' ? ' active' : '' %>">
                                <span class="nav-icon">🌐</span><span>CDN Pool</span>
                            </a>
                            <% } %>
                                <div class="nav-divider"></div>
                                <a href="/play" class="nav-item" target="_blank">
                                    <span class="nav-icon">▶️</span>
                                    <span>Player Demo</span>
                                </a>
            </nav>
            <div class="sidebar-footer">
                <% if (typeof currentUser !=='undefined' && currentUser) { %>
                    <div class="user-info">
                        <div class="user-name">
                            <%= currentUser.display_name || currentUser.username %>
                        </div>
                        <div class="user-role">
                            <span class="badge badge-<%= currentUser.role === 'administrator' ? 'live' : 'unknown' %>"
                                style="font-size:9px;padding:2px 6px;">
                                <%= currentUser.role==='administrator' ? 'ADMIN' : 'UPLOADER' %>
                            </span>
                        </div>
                    </div>
                    <a href="/auth/logout" class="nav-item" style="margin-top:8px;font-size:13px;color:var(--danger);">
                        <span class="nav-icon">🚪</span>
                        <span>Đăng xuất</span>
                    </a>
                    <% } %>
                        <span class="version">v1.0.0</span>
            </div>
        </aside>
        <main class="main-content">
            <header class="content-header">
                <h1>
                    <%= typeof title !=='undefined' ? title : '' %>
                </h1>
            </header>
            <div class="content-body">