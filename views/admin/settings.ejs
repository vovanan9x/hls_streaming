<%- include('../partials/header') %>

    <% if (success) { %>
        <div class="alert alert-success">✅ <%= success %>
        </div>
        <% } %>
            <% if (error) { %>
                <div class="alert alert-error">⚠️ <%= error %>
                </div>
                <% } %>

                    <div class="card">
                        <div class="card-title">☁️ Cloudflare R2 Storage</div><br>
                        <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                            Sau khi cấu hình, video sẽ tự động upload lên R2 sau khi encode.
                            CDN URL sẽ được lưu làm <code>m3u8_url</code>.
                            <% if (r2Configured) { %><span style="color:#34d399;margin-left:8px">✅ Đang kết nối</span>
                                <% } else { %><span style="color:#f87171;margin-left:8px">⛔ Chưa cấu hình</span>
                                    <% } %>
                        </p>
                        <form action="/admin/settings/r2" method="POST">
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                                <div class="form-group">
                                    <label class="form-label">Account ID</label>
                                    <input type="text" name="r2_account_id" class="form-input"
                                        value="<%= r2Cfg.accountId || '' %>" placeholder="abc123...">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Bucket Name</label>
                                    <input type="text" name="r2_bucket" class="form-input"
                                        value="<%= r2Cfg.bucket || '' %>" placeholder="my-hls-bucket">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Access Key ID</label>
                                    <input type="text" name="r2_access_key" class="form-input"
                                        value="<%= r2Cfg.accessKeyId || '' %>" placeholder="Access Key">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Secret Access Key</label>
                                    <input type="password" name="r2_secret_key" class="form-input"
                                        placeholder="Secret Key (để trống = không đổi)" autocomplete="off">
                                </div>
                                <div class="form-group" style="grid-column:1/-1">
                                    <label class="form-label">Public CDN URL</label>
                                    <input type="url" name="r2_public_url" class="form-input"
                                        value="<%= r2Cfg.publicUrl || '' %>" placeholder="https://cdn.yourdomain.com">
                                    <small style="color:var(--text-muted)">Domain CDN trỏ vào R2 bucket của bạn (không
                                        có dấu / cuối)</small>
                                </div>
                            </div>
                            <div style="display:flex;gap:10px;margin-top:16px;">
                                <button type="submit" class="btn btn-primary">💾 Lưu cấu hình R2</button>
                                <button type="button" class="btn btn-ghost" id="test-r2-btn">🔌 Test kết nối</button>
                            </div>
                        </form>
                        <div id="r2-test-result" style="margin-top:12px;font-size:13px;display:none;"></div>
                    </div>

                    <div class="card" style="margin-top:20px">
                        <div class="card-title">🔑 API Token</div><br>
                        <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                            Token dùng để xác thực cho Public API <code>/api/v1/videos</code>.
                            Gửi kèm header: <code>Authorization: Bearer &lt;token&gt;</code>
                        </p>
                        <% if (apiToken) { %>
                            <div
                                style="display:flex;align-items:center;gap:10px;background:var(--bg-input);padding:12px 16px;border-radius:var(--radius);margin-bottom:14px;font-family:monospace;font-size:13px;word-break:break-all;">
                                <span id="token-text">
                                    <%= apiToken %>
                                </span>
                                <button type="button" onclick="copyToken()" class="btn btn-ghost btn-sm"
                                    style="flex-shrink:0">📋 Copy</button>
                            </div>
                            <form action="/admin/settings/token/revoke" method="POST" style="display:inline">
                                <button class="btn btn-ghost" style="color:#f87171">🗑 Thu hồi token</button>
                            </form>
                            <% } else { %>
                                <p style="color:var(--text-muted);margin-bottom:14px">Chưa có token nào được tạo.</p>
                                <form action="/admin/settings/token/generate" method="POST">
                                    <button class="btn btn-primary">⚡ Tạo API Token</button>
                                </form>
                                <% } %>
                    </div>

                    <div class="card" style="margin-top:20px">
                        <div class="card-title">📖 Public API Docs</div><br>
                        <div style="font-size:13px;color:var(--text-muted);line-height:1.9">
                            <strong>Base URL:</strong>
                            <code><%= typeof baseUrl !== 'undefined' ? baseUrl : '' %>/api/v1</code><br>
                            <strong>Auth:</strong> <code>Authorization: Bearer &lt;token&gt;</code> hoặc
                            <code>?token=&lt;token&gt;</code><br><br>
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr style="border-bottom:1px solid var(--border-color)">
                                        <th style="text-align:left;padding:6px 10px">Endpoint</th>
                                        <th style="text-align:left;padding:6px 10px">Mô tả</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos</code></td>
                                        <td style="padding:6px 10px">Danh sách video (public). Query:
                                            <code>?page=1&limit=20</code></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos/:id</code></td>
                                        <td style="padding:6px 10px">Chi tiết 1 video</td>
                                    </tr>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos/:id/stream</code></td>
                                        <td style="padding:6px 10px">Redirect đến m3u8 URL</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <script>
                        document.getElementById('test-r2-btn').addEventListener('click', function () {
                            const btn = this, result = document.getElementById('r2-test-result');
                            btn.textContent = '⏳ Đang test...'; btn.disabled = true;
                            fetch('/admin/settings/r2/test', { method: 'POST' })
                                .then(r => r.json()).then(data => {
                                    result.style.display = 'block';
                                    result.innerHTML = data.ok
                                        ? '<span style="color:#34d399">✅ ' + data.message + '</span>'
                                        : '<span style="color:#f87171">❌ ' + data.message + '</span>';
                                }).finally(() => { btn.textContent = '🔌 Test kết nối'; btn.disabled = false; });
                        });
                        function copyToken() {
                            navigator.clipboard.writeText(document.getElementById('token-text').textContent);
                            event.target.textContent = '✅'; setTimeout(() => { event.target.textContent = '📋 Copy'; }, 1500);
                        }
                    </script>

                    <%- include('../partials/footer') %>