<%- include('../partials/header') %>

<% if (success) { %>
<script>window.__pageToast = { msg: <%- JSON.stringify(success) %>, type: 'success' };</script>
<% } %>
<% if (error) { %>
<script>window.__pageToast = { msg: '⚠️ Có lỗi xảy ra', type: 'error' };</script>
<% } %>

<style>
  .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 900px) { .settings-grid { grid-template-columns: 1fr; } }
  .settings-section { margin-bottom: 28px; }
  .section-title {
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.2px;
    color: var(--text-muted); margin-bottom: 14px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 8px;
  }
  .section-title svg { width: 14px; height: 14px; opacity: 0.6; }
  .setting-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 18px 20px; margin-bottom: 14px;
  }
  .setting-card h4 { font-size: 13.5px; font-weight: 600; color: var(--text-primary); margin: 0 0 6px 0; display: flex; align-items: center; gap: 6px; }
  .setting-card h4 .icon { font-size: 15px; }
  .setting-card .desc { font-size: 12.5px; color: var(--text-muted); margin-bottom: 14px; line-height: 1.5; }
  .setting-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .setting-row label { font-size: 12px; color: var(--text-muted); white-space: nowrap; }
  .status-pill {
    display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 500;
    padding: 4px 10px; border-radius: 20px;
  }
  .status-pill.on  { background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.2); }
  .status-pill.off { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
  .input-mono {
    background: var(--bg-input); border: 1px solid var(--border); border-radius: 8px;
    padding: 8px 12px; font-family: monospace; font-size: 12px; color: var(--text-primary);
  }
  .sa-status {
    display: flex; align-items: center; gap: 8px; font-size: 12.5px;
    padding: 8px 12px; border-radius: 8px; margin-bottom: 12px;
  }
</style>

<!-- ═══════ SECTION: Giao diện ═══════ -->
<div class="settings-section">
  <div class="section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Giao diện
  </div>
  <div class="setting-card">
    <h4><span class="icon">📄</span> Số kết quả / trang</h4>
    <p class="desc">Áp dụng cho tất cả danh sách: Video, Lỗi, Tài khoản, Yêu cầu xoá.</p>
    <form action="/admin/settings/page-size" method="POST" class="setting-row">
      <select name="page_size" class="form-select" style="width:auto;">
        <% [10,15,20,30,50,100].forEach(function(n) { %>
          <option value="<%= n %>" <%= (currentPageSize || 20) == n ? 'selected' : '' %>><%= n %> / trang</option>
        <% }); %>
      </select>
      <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
    </form>
  </div>
</div>

<!-- ═══════ SECTION: Bảo mật ═══════ -->
<div class="settings-section">
  <div class="section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    Bảo mật
  </div>

  <div class="settings-grid">
    <!-- Signed URL -->
    <div class="setting-card">
      <h4><span class="icon">🔒</span> Signed URL (Chống Hotlink)</h4>
      <p class="desc">
        Bảo vệ link HLS bằng token + thời hạn.<br>
        <span style="color:#94a3b8;">Cần cấu hình nginx <code>secure_link</code> trên storage server. <a href="/admin/guide" style="color:var(--accent);">Xem hướng dẫn</a></span>
      </p>

      <% if (signedUrlSecret) { %>
        <span class="status-pill on">🔒 BẬT — TTL: <%= signedUrlTtl %> giờ</span>
      <% } else { %>
        <span class="status-pill off">⚠ TẮT — link không được bảo vệ</span>
      <% } %>

      <form action="/admin/settings/signed-url" method="POST" style="margin-top:14px;">
        <div style="margin-bottom:10px;">
          <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px;">Secret Key</label>
          <div style="display:flex;gap:8px;">
            <input type="text" name="signed_url_secret" id="signed-url-secret" value="<%= signedUrlSecret %>"
              class="input-mono" style="flex:1;" placeholder="Nhập hoặc tự tạo">
            <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('signed-url-secret').value=Array.from(crypto.getRandomValues(new Uint8Array(24)),b=>b.toString(16).padStart(2,'0')).join('')">🔄</button>
          </div>
        </div>
        <div class="setting-row" style="margin-bottom:12px;">
          <label>TTL:</label>
          <select name="signed_url_ttl" class="form-select" style="width:auto;">
            <% [1,2,4,8,12,24,48,72].forEach(function(h) { %>
              <option value="<%= h %>" <%= (signedUrlTtl || '4') == h ? 'selected' : '' %>><%= h %> giờ</option>
            <% }); %>
          </select>
        </div>
        <div class="setting-row">
          <button type="submit" class="btn btn-primary btn-sm">💾 Lưu</button>
          <% if (signedUrlSecret) { %>
            <button type="button" class="btn btn-ghost btn-sm" style="color:#f87171;" onclick="if(confirm('Tắt Signed URL?')){document.getElementById('signed-url-secret').value='';this.closest('form').submit();}">🔓 Tắt</button>
          <% } %>
        </div>
      </form>
    </div>

    <!-- Rate Limiting -->
    <div class="setting-card">
      <h4><span class="icon">🛡️</span> Rate Limiting</h4>
      <p class="desc">
        Giới hạn số request mỗi phút theo IP. Chống brute-force đăng nhập và lạm dụng API.
      </p>

      <form action="/admin/settings/rate-limit" method="POST">
        <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:14px;">
          <div class="setting-row">
            <label style="min-width:100px;">Đăng nhập:</label>
            <input type="number" name="rate_limit_login" value="<%= rateLimitLogin %>" min="1" max="1000"
              class="input-mono" style="width:80px;text-align:center;">
            <span style="font-size:12px;color:var(--text-muted);">req/phút</span>
          </div>
          <div class="setting-row">
            <label style="min-width:100px;">API:</label>
            <input type="number" name="rate_limit_api" value="<%= rateLimitApi %>" min="1" max="1000"
              class="input-mono" style="width:80px;text-align:center;">
            <span style="font-size:12px;color:var(--text-muted);">req/phút</span>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">💾 Lưu</button>
      </form>
    </div>
  </div>
</div>

<!-- ═══════ SECTION: Tích hợp ═══════ -->
<div class="settings-section">
  <div class="section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    Tích hợp
  </div>

  <div class="settings-grid">
    <!-- Google Drive SA -->
    <div class="setting-card">
      <h4><span class="icon">☁️</span> Google Drive API</h4>
      <p class="desc">Service Account để tải file Drive không giới hạn, không virus-scan.</p>

      <% if (driveServiceEmail) { %>
        <div class="sa-status" style="background:rgba(52,211,153,0.08);border:1px solid rgba(52,211,153,0.2);">
          <span style="color:#34d399;">✔</span>
          <code style="font-size:11.5px;flex:1;word-break:break-all;"><%= driveServiceEmail %></code>
          <button type="button" id="test-sa-btn" onclick="testSA()" class="btn btn-ghost btn-sm" style="flex-shrink:0;">🔍 Test</button>
        </div>
      <% } else { %>
        <div class="sa-status" style="background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.2);color:#fbbf24;">
          ⚠ Chưa cấu hình — dùng chế độ public (có thể bị giới hạn)
        </div>
      <% } %>

      <div id="sa-test-result" style="display:none;margin-bottom:10px;font-size:12px;padding:6px 10px;border-radius:6px;"></div>

      <form action="/admin/settings/gdrive-sa" method="POST">
        <div style="margin-bottom:10px;">
          <label style="font-size:12px;color:var(--text-muted);display:block;margin-bottom:4px;">JSON Key</label>
          <textarea name="service_account_json" rows="4"
            style="width:100%;background:var(--bg-input);border:1px solid var(--border);border-radius:8px;padding:8px 10px;font-family:monospace;font-size:11px;color:var(--text-primary);resize:vertical;"
            placeholder='{"type":"service_account","client_email":"...","private_key":"..."}'></textarea>
        </div>
        <div class="setting-row">
          <button type="submit" class="btn btn-primary btn-sm">💾 Lưu SA</button>
          <% if (driveServiceEmail) { %>
            <form action="/admin/settings/gdrive-sa/remove" method="POST" style="margin:0;">
              <button type="submit" class="btn btn-ghost btn-sm" style="color:#f87171;" onclick="return confirm('Xoá Service Account?')">🗑 Xoá</button>
            </form>
          <% } %>
        </div>
      </form>
    </div>

    <!-- Server lưu trữ -->
    <div class="setting-card">
      <h4><span class="icon">🖥️</span> Server lưu trữ</h4>
      <p class="desc">SFTP (Hetzner, VPS) và Cloudflare R2 được quản lý tập trung.</p>
      <div class="setting-row">
        <a href="/admin/servers" class="btn btn-primary btn-sm">🖥️ Quản lí Server</a>
        <a href="/admin/servers/add" class="btn btn-ghost btn-sm">➕ Thêm mới</a>
      </div>
    </div>
  </div>
</div>

<!-- ═══════ SECTION: API ═══════ -->
<div class="settings-section">
  <div class="section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    API
  </div>

  <div class="settings-grid">
    <!-- API Token -->
    <div class="setting-card">
      <h4><span class="icon">🔑</span> API Token</h4>
      <p class="desc">Token xác thực cho Public API <code>/api/v1</code>. Header: <code>Authorization: Bearer &lt;token&gt;</code></p>

      <% if (apiToken) { %>
        <div style="display:flex;align-items:center;gap:8px;background:var(--bg-input);padding:10px 12px;border-radius:8px;margin-bottom:10px;font-family:monospace;font-size:12px;word-break:break-all;">
          <span id="token-text" style="flex:1;"><%= apiToken %></span>
          <button type="button" onclick="copyToken()" class="btn btn-ghost btn-sm" style="flex-shrink:0;">📋</button>
        </div>
        <form action="/admin/settings/token/revoke" method="POST" style="display:inline;">
          <button class="btn btn-ghost btn-sm" style="color:#f87171;">🗑 Thu hồi</button>
        </form>
      <% } else { %>
        <p style="color:var(--text-muted);margin-bottom:10px;font-size:12.5px;">Chưa có token.</p>
        <form action="/admin/settings/token/generate" method="POST">
          <button class="btn btn-primary btn-sm">⚡ Tạo API Token</button>
        </form>
      <% } %>
    </div>

    <!-- API Docs mini -->
    <div class="setting-card">
      <h4><span class="icon">📖</span> API Endpoints</h4>
      <p class="desc">Base: <code><%= typeof baseUrl !== 'undefined' ? baseUrl : '' %>/api/v1</code></p>
      <table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead>
          <tr style="border-bottom:1px solid var(--border);">
            <th style="text-align:left;padding:5px 8px;color:var(--text-muted);">Endpoint</th>
            <th style="text-align:left;padding:5px 8px;color:var(--text-muted);">Mô tả</th>
          </tr>
        </thead>
        <tbody>
          <tr><td style="padding:5px 8px;"><code>GET /videos</code></td><td style="padding:5px 8px;color:var(--text-secondary);">Danh sách video</td></tr>
          <tr><td style="padding:5px 8px;"><code>GET /videos/:id</code></td><td style="padding:5px 8px;color:var(--text-secondary);">Chi tiết video</td></tr>
          <tr><td style="padding:5px 8px;"><code>GET /videos/:id/stream</code></td><td style="padding:5px 8px;color:var(--text-secondary);">Redirect m3u8</td></tr>
          <tr><td style="padding:5px 8px;"><code>POST /upload/url</code></td><td style="padding:5px 8px;color:var(--text-secondary);">Upload từ URL</td></tr>
          <tr><td style="padding:5px 8px;"><code>POST /upload/drive</code></td><td style="padding:5px 8px;color:var(--text-secondary);">Upload từ Drive</td></tr>
        </tbody>
      </table>
      <div style="margin-top:10px;">
        <a href="/admin/api-docs" class="btn btn-ghost btn-sm" style="font-size:12px;">📚 Xem API Docs đầy đủ</a>
      </div>
    </div>
  </div>
</div>

<script>
  function copyToken() {
    navigator.clipboard.writeText(document.getElementById('token-text').textContent.trim());
    event.target.textContent = '✅'; setTimeout(() => { event.target.textContent = '📋'; }, 1500);
  }

  async function testSA() {
    const btn = document.getElementById('test-sa-btn');
    const result = document.getElementById('sa-test-result');
    if (btn) { btn.textContent = '⏳...'; btn.disabled = true; }
    try {
      const r = await fetch('/admin/api/gdrive/test');
      const data = await r.json();
      if (result) {
        result.style.display = 'block';
        if (data.ok) {
          result.style.background = 'rgba(52,211,153,0.08)';
          result.style.border = '1px solid rgba(52,211,153,0.2)';
          result.style.color = '#34d399';
          result.textContent = '✔ Kết nối thành công!';
        } else {
          result.style.background = 'rgba(239,68,68,0.08)';
          result.style.border = '1px solid rgba(239,68,68,0.2)';
          result.style.color = '#f87171';
          result.textContent = '✖ ' + (data.error || 'Lỗi');
        }
      }
    } catch (e) {
      if (result) { result.style.display = 'block'; result.textContent = '✖ Lỗi: ' + e.message; }
    } finally {
      if (btn) { btn.textContent = '🔍 Test'; btn.disabled = false; }
    }
  }
</script>

<%- include('../partials/footer') %>