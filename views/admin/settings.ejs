<%- include('../partials/header') %>

    <% if (success) { %>
        <div class="alert alert-success">✅ <%= success %>
        </div>
        <% } %>
            <% if (error) { %>
                <div class="alert alert-error">⚠️ <%= error %>
                </div>
                <% } %>

                    <!-- R2 & SFTP đã chuyển sang Quản lí Server -->
                    <div class="card" style="margin-bottom:20px;">
                        <div class="card-title">🖥️ Quản lí Server lưu trữ</div>
                        <br>
                        <p style="font-size:14px;color:var(--text-muted);margin-bottom:16px;">
                            Server SFTP (Hetzner, VPS...) và Cloudflare R2 được quản lý tập trung tại mục <strong>Quản
                                lí Server</strong>.
                            Mỗi server có thể được chọn riêng biệt khi upload video.
                        </p>
                        <a href="/admin/servers" class="btn btn-primary" style="margin-right:10px;">🖥️ Quản lí
                            Server</a>
                        <a href="/admin/servers/add" class="btn btn-ghost">➕ Thêm Server mới</a>
                    </div>

                    <div class="card" style="margin-top:20px">
                        <div class="card-title">🔑 API Token</div><br>
                        <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                            Token dùng để xác thực cho Public API <code>/api/v1/videos</code>.
                            Gửi kèm header: <code>Authorization: Bearer &lt;token&gt;</code>
                        </p>
                        <% if (apiToken) { %>
                            <div
                                style="display:flex;align-items:center;gap:10px;background:var(--bg-input);padding:12px 16px;border-radius:var(--radius);margin-bottom:14px;font-family:monospace;font-size:13px;word-break:break-all;">
                                <span id="token-text">
                                    <%= apiToken %>
                                </span>
                                <button type="button" onclick="copyToken()" class="btn btn-ghost btn-sm"
                                    style="flex-shrink:0">📋 Copy</button>
                            </div>
                            <form action="/admin/settings/token/revoke" method="POST" style="display:inline">
                                <button class="btn btn-ghost" style="color:#f87171">🗑 Thu hồi token</button>
                            </form>
                            <% } else { %>
                                <p style="color:var(--text-muted);margin-bottom:14px">Chưa có token nào được tạo.</p>
                                <form action="/admin/settings/token/generate" method="POST">
                                    <button class="btn btn-primary">⚡ Tạo API Token</button>
                                </form>
                                <% } %>
                    </div>

                    <div class="card" style="margin-top:20px">
                        <div class="card-title">📖 Public API Docs</div><br>
                        <div style="font-size:13px;color:var(--text-muted);line-height:1.9">
                            <strong>Base URL:</strong>
                            <code><%= typeof baseUrl !== 'undefined' ? baseUrl : '' %>/api/v1</code><br>
                            <strong>Auth:</strong> <code>Authorization: Bearer &lt;token&gt;</code> hoặc
                            <code>?token=&lt;token&gt;</code><br><br>
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr style="border-bottom:1px solid var(--border-color)">
                                        <th style="text-align:left;padding:6px 10px">Endpoint</th>
                                        <th style="text-align:left;padding:6px 10px">Mô tả</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos</code></td>
                                        <td style="padding:6px 10px">Danh sách video (public). Query:
                                            <code>?page=1&limit=20</code></td>
                                    </tr>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos/:id</code></td>
                                        <td style="padding:6px 10px">Chi tiết 1 video</td>
                                    </tr>
                                    <tr>
                                        <td style="padding:6px 10px"><code>GET /api/v1/videos/:id/stream</code></td>
                                        <td style="padding:6px 10px">Redirect đến m3u8 URL</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <script>
                        function copyToken() {
                            navigator.clipboard.writeText(document.getElementById('token-text').textContent);
                            event.target.textContent = '✅'; setTimeout(() => { event.target.textContent = '📋 Copy'; }, 1500);
                        }
                    </script>

                    <%- include('../partials/footer') %>