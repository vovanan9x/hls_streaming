<%- include('../partials/header') %>

    <% if (error) { %>
        <div class="alert alert-error">⚠️ <%= error %>
        </div>
        <% } %>
            <% if (success) { %>
                <div class="alert alert-success">✅ <%= success %>
                </div>
                <% } %>

                    <a href="/admin/users" class="btn btn-ghost" style="margin-bottom:20px;">← Quay lại danh sách</a>

                    <form action="/admin/users/<%= user ? user.id + '/edit' : 'add' %>" method="POST">
                        <div class="card">
                            <div class="card-title">
                                <%= user ? 'Sửa Tài khoản #' + user.id : 'Thêm Tài khoản mới' %>
                            </div>
                            <br>

                            <% if (!user) { %>
                                <div class="form-group">
                                    <label class="form-label">Username *</label>
                                    <input type="text" name="username" class="form-input" value=""
                                        placeholder="Nhập username..." required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Mật khẩu *</label>
                                    <input type="password" name="password" class="form-input"
                                        placeholder="Nhập mật khẩu..." required>
                                </div>
                                <% } else { %>
                                    <div class="form-group">
                                        <label class="form-label">Username</label>
                                        <input type="text" class="form-input" value="<%= user.username %>" disabled
                                            style="opacity:0.6">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">Đổi mật khẩu (để trống nếu không đổi)</label>
                                        <input type="password" name="new_password" class="form-input"
                                            placeholder="Nhập mật khẩu mới...">
                                    </div>
                                    <% } %>

                                        <div class="form-group">
                                            <label class="form-label">Tên hiển thị</label>
                                            <input type="text" name="display_name" class="form-input"
                                                value="<%= user ? user.display_name || '' : '' %>"
                                                placeholder="VD: Nguyễn Văn A">
                                        </div>

                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">Vai trò</label>
                                                <select name="role" class="form-select">
                                                    <option value="uploader" <%=(user && user.role==='uploader' ) ||
                                                        !user ? 'selected' : '' %>>Uploader — Chỉ upload & xem m3u8
                                                    </option>
                                                    <option value="administrator" <%=user && user.role==='administrator'
                                                        ? 'selected' : '' %>>Administrator — Full quyền hạn</option>
                                                </select>
                                            </div>
                                            <% if (user) { %>
                                                <div class="form-group">
                                                    <label class="form-label">Trạng thái</label>
                                                    <select name="is_active" class="form-select">
                                                        <option value="1" <%=user.is_active ? 'selected' : '' %>>Active
                                                        </option>
                                                        <option value="" <%=!user.is_active ? 'selected' : '' %>
                                                            >Disabled</option>
                                                    </select>
                                                </div>
                                                <% } %>
                                        </div>
                        </div>

                        <div style="display:flex;gap:10px;">
                            <button type="submit" class="btn btn-primary" style="padding:11px 28px;">
                                💾 <%= user ? 'Lưu thay đổi' : 'Thêm Tài khoản' %>
                            </button>
                            <a href="/admin/users" class="btn btn-ghost" style="padding:11px 28px;">Huỷ</a>
                        </div>
                    </form>

                    <%- include('../partials/footer') %>