            <tr><td>drive_url <span class="req-tag">bắt buộc</span></td><td>string</td><td>Link Drive (/file/d/ID/view hoặc ?id=ID)</td></tr>
            <tr><td>title <span class="req-tag">bắt buộc</span></td><td>string</td><td>Tiêu đề video</td></tr>
            <tr><td>server_id <span class="req-tag">bắt buộc</span></td><td>number</td><td>ID storage server</td></tr>
            <tr><td>qualities <span class="opt-tag">tuỳ chọn</span></td><td>array</td><td>["360p","720p","1080p"]</td></tr>
          </tbody>
        </table>
        <pre class="code-block"><button class="copy-code-btn" onclick="copyCode(this)">Copy</button>curl -X POST <span class="string">http://localhost:3000/api/v1/upload/drive</span> \
  -H "<span class="key">Authorization</span>: Bearer YOUR_TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"<span class="key">drive_url</span>":"<span class="string">https://drive.google.com/file/d/1ABC/view</span>","<span class="key">title</span>":"<span class="string">Video</span>","<span class="key">server_id</span>":1}'</pre>
      </div>

      <div class="api-card">
        <h3><span class="method-badge method-get">GET</span> Trạng thái upload</h3>
        <div class="endpoint">/api/v1/upload/:id/status</div>
        <p style="font-size:13px;color:#b0b0d0;margin-bottom:8px;">Poll API này để theo dõi tiến trình encode sau khi upload.</p>
        <pre class="code-block"><button class="copy-code-btn" onclick="copyCode(this)">Copy</button><span class="comment">// Đang xử lý</span>
{ "<span class="key">id</span>": 15, "<span class="key">status</span>": "processing", "<span class="key">progress</span>": 45, "<span class="key">m3u8_url</span>": null }

<span class="comment">// Hoàn thành</span>
{ "<span class="key">id</span>": 15, "<span class="key">status</span>": "ready", "<span class="key">progress</span>": 100, "<span class="key">m3u8_url</span>": "<span class="string">http://...</span>" }</pre>
        <p style="font-size:12px;color:#8888aa;margin-top:8px;">
          Trạng thái: <code style="color:#f59e0b">queued</code> → <code style="color:#8b5cf6">processing</code> → <code style="color:#3b82f6">uploading</code> → <code style="color:#22c55e">ready</code> | <code style="color:#ef4444">error</code>
        </p>
      </div>

      <!-- Server IDs -->
      <% if (servers && servers.length > 0) { %>
      <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:14px;">
        <div style="font-weight:700;font-size:13px;margin-bottom:12px;color:var(--text-primary);">🖥️ Danh sách server_id</div>
        <table class="param-table">
          <thead><tr><th>server_id</th><th>Label</th><th>Loại</th></tr></thead>
          <tbody>
            <% servers.forEach(function(s) { %>
            <tr>
              <td><strong><%= s.id %></strong></td>
              <td><%= s.label %></td>
              <td><%= s.server_type === 'r2' ? '☁️ Cloudflare R2' : '🖥️ SFTP' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ─── TAB: SIGNED URL ─── -->
  <div id="tab-signed-url" class="guide-section">
    <h2 class="section-title">🔒 Cấu hình Signed URL (Chống Hotlink)</h2>

    <div class="info-box">
      <strong>Mục đích:</strong> Bảo vệ link HLS khỏi bị người khác lấy chèn vào website họ, gây lãng phí băng thông.<br>
      Mỗi URL m3u8 sẽ kèm token + thời hạn. Hết hạn → nginx trả 403/410.
    </div>

    <div class="step-row">
      <span class="step-num">1</span>
      <span><strong>Bật Signed URL trên app server</strong></span>
    </div>
    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:12px;padding-left:30px;">
      Vào <a href="/admin/settings" style="color:var(--accent);">Cài đặt</a> → phần <strong>Signed URL</strong> → nhấn 🔄 Tạo secret key → chọn TTL → Lưu.
    </p>

    <div class="step-row">
      <span class="step-num">2</span>
      <span><strong>Cấu hình nginx trên Storage Server</strong></span>
    </div>
    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:8px;padding-left:30px;">
      Mở config nginx và thêm <code>secure_link</code> vào <code>location /hls/</code>:
    </p>
    <pre class="code-block"><button class="copy-code-btn" onclick="copyCode(this)">Copy</button><span class="comment"># /etc/nginx/sites-available/hls-storage</span>

server {
    listen 80;
    server_name st1.ahay.stream;
    root /var/www/hls-storage;

    <span class="comment"># HLS files - Signed URL protection</span>
    location /hls/ {
        <span class="key">secure_link</span> $arg_token,$arg_expires;
        <span class="key">secure_link_md5</span> <span class="string">"$arg_expires$uri YOUR_SECRET_KEY"</span>;

        <span class="comment"># Token không hợp lệ → 403</span>
        if ($secure_link = "") {
            return 403;
        }
        <span class="comment"># Token hết hạn → 410 Gone</span>
        if ($secure_link = "0") {
            return 410;
        }

        <span class="comment"># CORS headers</span>
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods 'GET, OPTIONS';
        add_header Access-Control-Allow-Headers 'Range';
        add_header Cache-Control "public, max-age=31536000";

        types {
            application/vnd.apple.mpegurl m3u8;
            video/mp2t ts;
        }
    }

    <span class="comment"># Thumbnails - không cần bảo vệ</span>
    location /thumbnails/ {
        add_header Access-Control-Allow-Origin *;
        add_header Cache-Control "public, max-age=86400";
    }
}</pre>

    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;padding:12px 16px;margin:16px 0;font-size:13px;">
      <strong style="color:#ef4444;">⚠️ Quan trọng:</strong>
      <span style="color:var(--text-secondary);">Thay <code>YOUR_SECRET_KEY</code> bằng đúng secret key đã tạo trong Cài đặt. Hai bên phải giống nhau!</span>
    </div>

    <div class="step-row">
      <span class="step-num">3</span>
      <span><strong>Kiểm tra nginx và reload</strong></span>
    </div>
    <pre class="code-block"><button class="copy-code-btn" onclick="copyCode(this)">Copy</button><span class="comment"># Kiểm tra config</span>
sudo nginx -t

<span class="comment"># Reload nginx</span>
sudo systemctl reload nginx</pre>

    <div class="step-row">
      <span class="step-num">4</span>
      <span><strong>Test bằng curl</strong></span>
    </div>
    <pre class="code-block"><button class="copy-code-btn" onclick="copyCode(this)">Copy</button><span class="comment"># Không có token → 403</span>
curl -I https://st1.ahay.stream/hls/24/master.m3u8

<span class="comment"># Có token hợp lệ → 200</span>
curl -I "https://st1.ahay.stream/hls/24/master.m3u8?token=xxx&expires=9999999999"</pre>

    <h3 style="margin-top:24px;color:var(--text-primary);">❓ Troubleshooting</h3>
    <table class="param-table">
      <thead>
        <tr><th>Vấn đề</th><th>Nguyên nhân</th><th>Giải pháp</th></tr>
      </thead>
      <tbody>
        <tr><td>Luôn trả 403</td><td>Secret key không khớp</td><td>Kiểm tra secret key trong Cài đặt và nginx config phải giống nhau</td></tr>
        <tr><td>410 Gone</td><td>Token hết hạn</td><td>Tăng TTL trong Cài đặt hoặc reload lại trang embed</td></tr>
        <tr><td>Video vẫn phát khi copy URL</td><td>Nginx chưa reload</td><td>Chạy <code>sudo systemctl reload nginx</code></td></tr>
        <tr><td>Lỗi "unknown directive secure_link"</td><td>Thiếu module</td><td><code>sudo apt install libnginx-mod-http-secure-link</code></td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  function switchTab(id) {
    document.querySelectorAll('.guide-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.guide-section').forEach(function(s) { s.classList.remove('active'); });
    document.getElementById('tab-' + id).classList.add('active');
    event.currentTarget.classList.add('active');
  }
  function copyCode(btn) {
    var pre = btn.parentElement;
    var text = pre.textContent.replace('Copy','').trim();
    navigator.clipboard.writeText(text).then(function() {
      btn.textContent = '✓ Copied';
      setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
    });
  }
  function copyApiToken() {
    var t = document.getElementById('guide-api-token');
    if (t) navigator.clipboard.writeText(t.textContent).then(function() { showToast('success', 'API Token đã copy!'); });
  }
  var baseEl = document.getElementById('guide-base-url');
  if (baseEl) baseEl.textContent = window.location.origin + '/api/v1';
</script>

