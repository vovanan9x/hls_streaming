<%- include('../partials/header') %>

<style>
  .guide-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    overflow-x: auto;
  }
  .guide-tab {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 11px 20px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
    font-family: var(--font);
  }
  .guide-tab:hover { color: var(--text-primary); }
  .guide-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .guide-section { display: none; }
  .guide-section.active { display: block; }

  .info-box {
    background: rgba(139,92,246,0.08);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
    font-size: 13px;
    line-height: 1.7;
  }
  .warn-box {
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.25);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
    font-size: 13px;
    color: #f59e0b;
    line-height: 1.7;
  }
  .step-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 20px 0 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .step-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  pre.code-block {
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 14px 16px;
    font-size: 12.5px;
    color: #c9d1d9;
    overflow-x: auto;
    line-height: 1.65;
    margin: 8px 0 16px;
    white-space: pre;
    position: relative;
  }
  pre.code-block .comment { color: #6e7681; }
  pre.code-block .key { color: #d2a8ff; }
  pre.code-block .string { color: #a5d6ff; }
  .copy-code-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(139,92,246,0.2);
    border: 1px solid rgba(139,92,246,0.3);
    color: var(--accent);
    border-radius: 5px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
  }
  .copy-code-btn:hover { background: rgba(139,92,246,0.35); }

  .method-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 2px 9px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }
  .method-get { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
  .method-post { background: rgba(139,92,246,0.15); color: #8b5cf6; border: 1px solid rgba(139,92,246,0.3); }

  .endpoint {
    font-family: monospace;
    font-size: 13px;
    color: var(--accent);
    background: rgba(139,92,246,0.08);
    padding: 7px 12px;
    border-radius: 7px;
    display: inline-block;
    margin: 4px 0 10px;
  }
  .param-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 12px; }
  .param-table th { text-align: left; padding: 8px 12px; color: #8888aa; font-weight: 600; border-bottom: 1px solid var(--border); }
  .param-table td { padding: 7px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top; }
  .param-table td:first-child { font-family: monospace; color: var(--accent); white-space: nowrap; }
  .req-tag { font-size: 9px; background: rgba(239,68,68,0.15); color: #ef4444; padding: 1px 6px; border-radius: 10px; font-weight: 700; margin-left: 4px; }
  .opt-tag { font-size: 9px; background: rgba(255,255,255,0.06); color: #8888aa; padding: 1px 6px; border-radius: 10px; font-weight: 600; margin-left: 4px; }

  .api-section { margin-bottom: 28px; }
  .api-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 20px; margin-bottom: 14px; }
  .api-card h3 { margin: 0 0 10px; font-size: 14px; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }

  .arch-diagram {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin: 16px 0;
  }
  .arch-node {
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.3);
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-align: center;
  }
  .arch-arrow {
    color: var(--text-muted);
    font-size: 18px;
  }
  .token-display {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(139,92,246,0.08);
    border: 1px solid rgba(139,92,246,0.2);
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
  }
  .token-display code {
    font-family: monospace;
    font-size: 13px;
    color: var(--accent);
    word-break: break-all;
    flex: 1;
  }
</style>

