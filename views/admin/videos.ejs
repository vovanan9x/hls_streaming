<%- include('../partials/header') %>

    <% var toastMsg='' ; var toastType='success' ; if (typeof msg !=='undefined' && msg==='requested' ) {
        toastMsg='Da gui yeu cau xoa. Vui long cho admin duyet.' ; } else if (typeof msg !=='undefined' &&
        msg==='already_pending' ) { toastMsg='Video nay da co yeu cau xoa dang cho duyet.' ; toastType='warn' ; } else
        if (typeof msg !=='undefined' && msg==='notfound' ) { toastMsg='Khong tim thay video.' ; toastType='error' ; }
        %>

        <% if (toastMsg) { %>
            <div class="toast toast-<%= toastType %>" id="page-toast"
                style="position:fixed;top:20px;right:20px;z-index:9999;padding:12px 20px;border-radius:8px;font-size:14px;max-width:380px;box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:opacity 0.4s;background:<%= toastType==='success'?'rgba(52,211,153,0.15)':toastType==='warn'?'rgba(234,179,8,0.15)':'rgba(239,68,68,0.15)' %>;border:1px solid <%= toastType==='success'?'rgba(52,211,153,0.3)':toastType==='warn'?'rgba(234,179,8,0.3)':'rgba(239,68,68,0.3)' %>;color:<%= toastType==='success'?'#34d399':toastType==='warn'?'#fbbf24':'#f87171' %>;">
                <% if (toastType==='success' ) { %>&#x2705;<% } else if (toastType==='warn' ) { %>&#x26A0;&#xFE0F;<% }
                            else { %>&#x274C;<% } %>
                                <%= toastMsg %>
            </div>
            <% } %>

                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Danh s&#xE1;ch Video (<%= videos.length %>)</span>
                        <a href="/admin/upload" class="btn btn-primary">&#x1F4E4; Upload m&#x1EDB;i</a>
                    </div>

                    <% if (videos.length===0) { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">&#x1F39E;&#xFE0F;</div>
                            <div class="empty-state-text">Ch&#x01B0;a c&#xF3; video n&#xE0;o</div>
                            <div class="empty-state-hint">B&#x1EAF;t &#x111;&#x1EA7;u b&#x1EB1;ng c&#xE1;ch upload video
                                &#x111;&#x1EA7;u ti&#xEA;n</div>
                        </div>
                        <% } else { %>
                            <div class="table-wrap">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Thumb</th>
                                            <th>Ti&#xEA;u &#x111;&#x1EC1;</th>
                                            <th>Uploader</th>
                                            <th>Server</th>
                                            <th>Tr&#x1EA1;ng th&#xE1;i</th>
                                            <th>&#x1F441;&#xFE0F; &#x110;ang xem</th>
                                            <th>Ng&#xE0;y t&#x1EA1;o</th>
                                            <th>H&#xE0;nh &#x111;&#x1ED9;ng</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% videos.forEach(function(v) { var isPending=pendingVideoIds.indexOf(v.id)
                                            !==-1; var
                                            isProcessing=['queued','processing','uploading'].includes(v.status); var
                                            isAdmin=typeof currentUser !=='undefined' && currentUser &&
                                            currentUser.role==='administrator' ; var isUploader=typeof currentUser
                                            !=='undefined' && currentUser && currentUser.role==='uploader' ; %>
                                            <tr>
                                                <td class="td-thumb">
                                                    <% if (v.thumbnail) { %>
                                                        <img src="/uploads/thumbnails/<%= v.thumbnail %>" alt="thumb">
                                                        <% } else { %>
                                                            <div
                                                                style="width:72px;height:42px;background:var(--bg-input);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:18px;">
                                                                &#x1F3AC;</div>
                                                            <% } %>
                                                </td>
                                                <td class="td-title">
                                                    <%= v.title %>
                                                        <small>ID: <%= v.id %> &middot; Sort: <%= v.sort_order %>
                                                                    </small>
                                                        <% if (v.qualities) { try { var qs=JSON.parse(v.qualities); }
                                                            catch(e) { var qs=[]; } %>
                                                            <% qs.forEach(function(q) { %><span
                                                                    style="display:inline-block;font-size:10px;padding:1px 5px;border-radius:3px;background:rgba(139,92,246,0.15);color:var(--accent);margin:2px 1px;font-weight:600">
                                                                    <%= q %>
                                                                </span>
                                                                <% }); %>
                                                                    <% } %>
                                                </td>
                                                <td style="color:var(--text-secondary);font-size:13px;">
                                                    <%= v.uploader_name || '&mdash;' %>
                                                </td>
                                                <td>
                                                    <% if (v.server_label) { %>
                                                        <span style="color:var(--text-secondary)">
                                                            <%= v.server_label %>
                                                        </span>
                                                        <% } else { %>
                                                            <span style="color:var(--text-muted)">Local</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <% if (v.status==='ready' ) { %>
                                                        <span class="badge badge-ready"
                                                            id="status-<%= v.id %>">READY</span>
                                                        <% } else if (v.status==='processing' ) { %>
                                                            <span class="badge badge-processing"
                                                                id="status-<%= v.id %>">PROCESSING (<%= v.progress || 0
                                                                    %>%)</span>
                                                            <% } else if (v.status==='uploading' ) { %>
                                                                <span class="badge badge-processing"
                                                                    id="status-<%= v.id %>"
                                                                    style="background:rgba(59,130,246,0.15);color:#60a5fa;">&#x2B06;&#xFE0F;
                                                                    UPLOADING...</span>
                                                                <% } else if (v.status==='error' ) { %>
                                                                    <span class="badge badge-error"
                                                                        id="status-<%= v.id %>">L&#x1ED6;I</span>
                                                                    <% } else if (v.status==='queued' ) { %>
                                                                        <span class="badge" id="status-<%= v.id %>"
                                                                            style="background:rgba(234,179,8,0.15);color:#fbbf24;">&#x23F3;
                                                                            QUEUE</span>
                                                                        <% } %>
                                                </td>
                                                <td id="viewers-<%= v.id %>"
                                                    style="text-align:center;font-size:13px;color:var(--text-muted);">
                                                    <span style="display:inline-flex;align-items:center;gap:4px;">
                                                        <span style="font-size:16px;">&#x1F441;&#xFE0F;</span>
                                                        <span class="viewer-count">0</span>
                                                    </span>
                                                </td>
                                                <td style="color:var(--text-muted);font-size:13px;white-space:nowrap">
                                                    <%= v.created_at %>
                                                </td>
                                                <td>
                                                    <div class="btn-group">
                                                        <% if (isProcessing) { %>
                                                            <button type="button" class="btn btn-danger btn-sm"
                                                                onclick="cancelVideo(<%= v.id %>)"
                                                                id="cancel-btn-<%= v.id %>">&#x26D4; H&#x1EE7;y</button>
                                                            <% } else if (isAdmin) { %>
                                                                <form action="/admin/videos/<%= v.id %>/push-top"
                                                                    method="POST" style="margin:0;">
                                                                    <button type="submit" class="btn btn-ghost btn-sm"
                                                                        title="Day len dau">&#x2B06;&#xFE0F;</button>
                                                                </form>
                                                                <a href="/admin/videos/<%= v.id %>/edit"
                                                                    class="btn btn-ghost btn-sm"
                                                                    title="Sua">&#x270F;&#xFE0F;</a>
                                                                <form action="/admin/videos/<%= v.id %>/delete"
                                                                    method="POST" class="delete-form"
                                                                    data-name="<%= v.title %>" style="margin:0;">
                                                                    <button type="submit" class="btn btn-danger btn-sm"
                                                                        title="Xoa">&#x1F5D1;&#xFE0F;</button>
                                                                </form>
                                                                <% } else if (isUploader) { %>
                                                                    <% if (isPending) { %>
                                                                        <button type="button" class="btn btn-sm"
                                                                            disabled
                                                                            style="opacity:0.6;cursor:not-allowed;background:rgba(234,179,8,0.1);color:#fbbf24;border:1px solid rgba(234,179,8,0.3);">
                                                                            &#x23F3; Ch&#x1EDD; duy&#x1EC7;t
                                                                        </button>
                                                                        <% } else { %>
                                                                            <button type="button"
                                                                                class="btn btn-danger btn-sm"
                                                                                onclick="openDeleteRequest(<%= v.id %>, this.dataset.title)"
                                                                                data-title="<%= v.title %>">
                                                                                &#x1F5D1;&#xFE0F; Y&#xEA;u c&#x1EA7;u
                                                                                Xo&#xE1;
                                                                            </button>
                                                                            <% } %>
                                                                                <% } %>
                                                                                    <% if (v.m3u8_url) { %>
                                                                                        <button
                                                                                            class="btn btn-ghost btn-sm copy-btn"
                                                                                            data-url="<%= v.m3u8_url %>"
                                                                                            title="Copy m3u8">&#x1F4CB;</button>
                                                                                        <% } %>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                </div>

                <!-- Modal yeu cau xoa -->
                <div id="dr-modal"
                    style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.6);align-items:center;justify-content:center;">
                    <div
                        style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:28px 32px;width:420px;max-width:94vw;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
                        <h3 style="margin:0 0 6px;font-size:17px;">&#x1F5D1;&#xFE0F; Y&#xEA;u c&#x1EA7;u Xo&#xE1; Video
                        </h3>
                        <p id="dr-modal-name" style="color:var(--text-secondary);font-size:13px;margin:0 0 16px;"></p>
                        <form id="dr-modal-form" method="POST" action="">
                            <label
                                style="display:block;font-size:13px;margin-bottom:6px;color:var(--text-secondary);">L&#xFD;
                                do xo&#xE1; <span style="color:var(--text-muted)">(tu&#x1EF3;
                                    ch&#x1ECD;n)</span></label>
                            <textarea name="reason" id="dr-modal-reason"
                                style="width:100%;box-sizing:border-box;min-height:80px;background:var(--bg-input);border:1px solid var(--border);border-radius:8px;color:var(--text-primary);padding:10px 12px;font-family:inherit;font-size:14px;resize:vertical;"
                                placeholder="Nhap ly do muon xoa video nay..."></textarea>
                            <div style="display:flex;gap:10px;margin-top:16px;justify-content:flex-end;">
                                <button type="button" class="btn btn-ghost" onclick="closeDrModal()">Hu&#x1EF7;</button>
                                <button type="submit" class="btn btn-danger">&#x1F5D1;&#xFE0F; G&#x1EED;i y&#xEA;u
                                    c&#x1EA7;u</button>
                            </div>
                        </form>
                    </div>
                </div>

                <script>
                    (function () {
                        // Toast auto-hide
                        var toast = document.getElementById('page-toast');
                        if (toast) { setTimeout(function () { toast.style.opacity = '0'; setTimeout(function () { if (toast.parentNode) toast.remove(); }, 400); }, 4500); }

                        // Admin: confirm before delete
                        document.querySelectorAll('.delete-form').forEach(function (f) {
                            f.addEventListener('submit', function (e) {
                                if (!confirm('Ban co chac xoa video: ' + this.dataset.name + '?')) e.preventDefault();
                            });
                        });

                        // Uploader: open delete request modal
                        window.openDeleteRequest = function (id, name) {
                            document.getElementById('dr-modal-name').textContent = String.fromCodePoint(0x1F4F9) + ' ' + name;
                            document.getElementById('dr-modal-form').action = '/admin/videos/' + id + '/delete-request';
                            document.getElementById('dr-modal-reason').value = '';
                            var m = document.getElementById('dr-modal');
                            m.style.display = 'flex';
                            setTimeout(function () { document.getElementById('dr-modal-reason').focus(); }, 50);
                        };
                        window.closeDrModal = function () { document.getElementById('dr-modal').style.display = 'none'; };
                        document.getElementById('dr-modal').addEventListener('click', function (e) { if (e.target === this) closeDrModal(); });

                        // Cancel video (AJAX)
                        window.cancelVideo = function (id) {
                            if (!confirm('Huy bo tien trinh va xoa video nay? Thao tac khong the hoan tac.')) return;
                            var btn = document.getElementById('cancel-btn-' + id);
                            if (btn) { btn.disabled = true; btn.textContent = '...'; }
                            fetch('/admin/api/videos/' + id + '/cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
                                .then(function (r) { return r.json(); })
                                .then(function (data) {
                                    if (data.ok) {
                                        var row = btn ? btn.closest('tr') : null;
                                        if (row) { row.style.opacity = '0'; row.style.transition = 'opacity 0.3s'; setTimeout(function () { row.remove(); }, 300); }
                                    } else {
                                        alert('Loi: ' + (data.message || 'Khong the huy.'));
                                        if (btn) { btn.disabled = false; btn.textContent = String.fromCodePoint(0x26D4) + ' Huy'; }
                                    }
                                }).catch(function (e) { alert('Loi ket noi.'); if (btn) { btn.disabled = false; } });
                        };

                        // Progress polling
                        var progressTimer = null;
                        function hasProcessing() { return document.querySelector('.badge-processing') !== null; }
                        function pollProgress() {
                            fetch('/admin/api/videos/progress').then(function (r) { return r.json(); }).then(function (vids) {
                                if (!vids || vids.length === 0) { clearInterval(progressTimer); location.reload(); return; }
                                vids.forEach(function (v) {
                                    var el = document.getElementById('status-' + v.id); if (!el) return;
                                    el.textContent = v.status === 'uploading' ? String.fromCodePoint(0x2B06, 0xFE0F) + ' UPLOADING...' : 'PROCESSING (' + Math.min(v.progress || 0, 100) + '%)';
                                });
                            }).catch(function () { });
                        }
                        if (hasProcessing()) { progressTimer = setInterval(pollProgress, 2000); }

                        // Viewer count polling
                        function pollViewers() {
                            fetch('/admin/api/viewers').then(function (r) { return r.json(); }).then(function (counts) {
                                document.querySelectorAll('[id^="viewers-"]').forEach(function (cell) {
                                    cell.querySelector('.viewer-count').textContent = '0';
                                    cell.style.color = 'var(--text-muted)'; cell.style.opacity = '0.5';
                                });
                                Object.keys(counts).forEach(function (videoId) {
                                    var count = counts[videoId]; var cell = document.getElementById('viewers-' + videoId);
                                    if (cell && count > 0) { cell.querySelector('.viewer-count').textContent = count; cell.style.color = '#34d399'; cell.style.opacity = '1'; cell.style.fontWeight = '600'; }
                                });
                            }).catch(function () { });
                        }
                        pollViewers();
                        setInterval(pollViewers, 5000);

                        // Copy m3u8
                        document.querySelectorAll('.copy-btn').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                var url = btn.getAttribute('data-url');
                                navigator.clipboard.writeText(url).then(function () {
                                    btn.textContent = String.fromCodePoint(0x2705);
                                    setTimeout(function () { btn.textContent = String.fromCodePoint(0x1F4CB); }, 1500);
                                });
                            });
                        });
                    })();
                </script>

                <%- include('../partials/footer') %>