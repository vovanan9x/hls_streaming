<%- include('../partials/header') %>

    <div class="card" style="text-align:center;padding:60px 40px;">
        <div style="font-size:64px;margin-bottom:16px;">🚫</div>
        <h2 style="font-size:20px;margin-bottom:8px;">Không có quyền truy cập</h2>
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:24px;">
            Tài khoản của bạn (<strong>
                <%= currentUser ? currentUser.username : '' %>
            </strong> —
            <span class="badge badge-<%= currentUser && currentUser.role === 'administrator' ? 'live' : 'unknown' %>">
                <%= currentUser ? currentUser.role.toUpperCase() : '' %>
            </span>)
            không có quyền truy cập trang này.
        </p>
        <a href="/admin/upload" class="btn btn-primary">← Quay lại Upload</a>
    </div>

    <%- include('../partials/footer') %>