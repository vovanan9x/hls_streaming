<%- include('../partials/header') %>

    <% if (error) { %>
        <div class="alert alert-error">⚠️ <%= error %>
        </div>
        <% } %>
            <% if (success) { %>
                <div class="alert alert-success">✅ <%= success %>
                </div>
                <% } %>

                    <a href="/admin/videos" class="btn btn-ghost" style="margin-bottom:20px;">← Quay lại danh sách</a>

                    <form action="/admin/videos/<%= video.id %>/edit" method="POST">
                        <div class="card">
                            <div class="card-title">Thông tin Video #<%= video.id %>
                            </div>
                            <br>
                            <div class="form-group">
                                <label class="form-label">Tiêu đề</label>
                                <input type="text" name="title" class="form-input" value="<%= video.title %>" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Mô tả</label>
                                <textarea name="description"
                                    class="form-textarea"><%= video.description || '' %></textarea>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Link M3U8</label>
                                    <input type="text" name="m3u8_url" class="form-input"
                                        value="<%= video.m3u8_url || '' %>" placeholder="/storage/hls/...">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Link Iframe</label>
                                    <input type="text" name="iframe_url" class="form-input"
                                        value="<%= video.iframe_url || '' %>" placeholder="/embed/...">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Trạng thái</label>
                                    <input type="text" class="form-input" value="<%= video.status %>" disabled
                                        style="opacity:0.6">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Cập nhật lần cuối</label>
                                    <input type="text" class="form-input" value="<%= video.updated_at %>" disabled
                                        style="opacity:0.6">
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-title">Preview</div>
                            <br>
                            <% if (video.thumbnail) { %>
                                <div style="margin-bottom:12px;">
                                    <img src="/uploads/thumbnails/<%= video.thumbnail %>"
                                        style="max-width:320px;border-radius:8px;border:1px solid var(--border-color);">
                                </div>
                                <% } %>
                                    <% if (video.m3u8_url) { %>
                                        <div style="margin-bottom:8px;">
                                            <span style="color:var(--text-muted);font-size:13px;">Player URL:</span>
                                            <a href="/embed/<%= video.id %>" target="_blank"
                                                style="color:var(--accent);font-size:13px;">/embed/<%= video.id %></a>
                                        </div>
                                        <% } %>
                        </div>

                        <div style="display:flex;gap:10px;">
                            <button type="submit" class="btn btn-primary" style="padding:11px 28px;">💾 Lưu thay
                                đổi</button>
                            <a href="/admin/videos" class="btn btn-ghost" style="padding:11px 28px;">Huỷ</a>
                        </div>
                    </form>

                    <%- include('../partials/footer') %>