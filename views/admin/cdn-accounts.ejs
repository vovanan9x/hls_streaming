<%- include('../partials/header', { title: 'CDN Domains (CF Pool)' }) %>

    <style>
        .cdn-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        @media(max-width:900px) {
            .cdn-grid {
                grid-template-columns: 1fr;
            }
        }

        .cdn-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
        }

        .cdn-card h3 {
            margin: 0 0 16px 0;
            font-size: 15px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .domains-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .domains-table th {
            text-align: left;
            padding: 8px 10px;
            background: var(--surface-2, #1a1a2e);
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 12px;
        }

        .domains-table td {
            padding: 9px 10px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .domains-table tr:last-child td {
            border-bottom: none;
        }

        .badge-active {
            background: #16a34a22;
            color: #4ade80;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-inactive {
            background: #dc262620;
            color: #f87171;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-pending {
            background: #ca8a0420;
            color: #fbbf24;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-awaiting {
            background: #7c3aed20;
            color: #a78bfa;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-running {
            background: #0ea5e920;
            color: #38bdf8;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-failed {
            background: #dc262620;
            color: #f87171;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .btn-xs {
            padding: 4px 10px;
            font-size: 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 500;
        }

        .btn-xs.danger {
            background: #dc2626;
            color: #fff;
        }

        .btn-xs.success {
            background: #16a34a;
            color: #fff;
        }

        .btn-xs.muted {
            background: var(--border);
            color: var(--text-secondary);
        }

        .btn-xs.info {
            background: #0ea5e9;
            color: #fff;
        }

        .log-box {
            background: #0d0d0d;
            border-radius: 8px;
            padding: 12px;
            font-family: monospace;
            font-size: 12px;
            max-height: 300px;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .log-line {
            color: #6ee7b7;
            margin: 2px 0;
        }

        .log-line.err {
            color: #f87171;
        }

        .log-line.warn {
            color: #fbbf24;
        }

        .form-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 12px;
            align-items: flex-end;
        }

        .form-row .form-group {
            flex: 1;
            min-width: 140px;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 4px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            background: var(--input-bg, #1a1a2e);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            padding: 8px 10px;
            font-size: 13px;
            box-sizing: border-box;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 70px;
        }

        .section-title {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 14px 0;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text);
        }

        #jobs-log {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .job-item {
            background: var(--surface-2, #1a1a2e);
            border-radius: 8px;
            padding: 12px;
            border: 1px solid var(--border);
        }

        .job-item .job-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .job-item .job-domain {
            font-weight: 600;
            font-size: 13px;
        }
    </style>

    <% if(msg==='added' ) { %>
        <div class="alert alert-success">✅ Domain đã được thêm!</div>
        <% } %>
            <% if(msg==='updated' ) { %>
                <div class="alert alert-success">✅ Đã cập nhật!</div>
                <% } %>
                    <% if(msg==='deleted' ) { %>
                        <div class="alert alert-success">✅ Đã xóa domain.</div>
                        <% } %>
                            <% if(msg==='duplicate' ) { %>
                                <div class="alert alert-error">❌ Domain đã tồn tại.</div>
                                <% } %>

                                            <div class="cdn-grid">
                                                <!-- ─── Panel 2: Thêm thủ công ─── -->
                                                <div class="cdn-card">
                                                    <h3>➕ Thêm Domain Thủ Công</h3>
                                                    <form action="/admin/cdn/add" method="POST">
                                                        <div class="form-group" style="margin-bottom:10px">
                                                            <label>Domain *</label>
                                                            <input type="text" name="domain"
                                                                placeholder="cdn01.site.com" required>
                                                        </div>
                                                        <div class="form-group" style="margin-bottom:10px">
                                                            <label>Label</label>
                                                            <input type="text" name="label" placeholder="CF Account #1">
                                                        </div>
                                                        <div class="form-group" style="margin-bottom:10px">
                                                            <label>Server liên kết</label>
                                                            <select name="server_id">
                                                                <option value="">-- Chọn server --</option>
                                                                <% servers.forEach(s=> { %>
                                                                    <option value="<%= s.id %>">
                                                                        <%= s.label %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select>
                                                        </div>
                                                        <div class="form-group" style="margin-bottom:10px">
                                                            <label>CF Email (tùy chọn)</label>
                                                            <input type="text" name="cf_email"
                                                                placeholder="abc@mail.tm">
                                                        </div>
                                                        <div class="form-group" style="margin-bottom:10px">
                                                            <label>CF API Token</label>
                                                            <input type="text" name="cf_api_token"
                                                                placeholder="Dán API token từ CF dashboard">
                                                        </div>
                                                        <div class="form-group" style="margin-bottom:12px">
                                                            <label>Ghi chú</label>
                                                            <input type="text" name="note" placeholder="...">
                                                        </div>
                                                        <button type="submit" class="btn btn-primary btn-sm">Thêm
                                                            Domain</button>
                                                    </form>
                                                </div>

                                                <!-- ─── Panel 3: CF Worker script ─── -->
                                                <div class="cdn-card">
                                                    <h3>📋 CF Worker Script (deploy thủ công)</h3>
                                                    <p
                                                        style="font-size:12px;color:var(--text-secondary);margin:0 0 10px">
                                                        Copy script này → Workers & Pages → Create Application → chọn
                                                        mỗi CF account. Route: <code>domain.com/hls/*</code>
                                                    </p>
                                                    <div class="log-box"
                                                        style="max-height:200px;color:#a5f3fc;font-size:11px;">
                                                        <pre style="margin:0;white-space:pre-wrap;">export default {
  async fetch(request) {
    const url = new URL(request.url);
    const response = await fetch(request);
    if (url.pathname.endsWith('.png')) {
      const h = new Headers(response.headers);
      h.set('Content-Type', 'video/mp2t');
      h.set('Access-Control-Allow-Origin', '*');
      h.set('Cache-Control', 'public, max-age=31536000, immutable');
      return new Response(response.body, { status: response.status, headers: h });
    }
    if (url.pathname.endsWith('.m3u8')) {
      const h = new Headers(response.headers);
      h.set('Access-Control-Allow-Origin', '*');
      h.set('Cache-Control', 'no-cache, no-store');
      return new Response(response.body, { status: response.status, headers: h });
    }
    return response;
  }
};</pre>
                                                    </div>
                                                    <button
                                                        onclick="navigator.clipboard.writeText(document.querySelector('.log-box pre').textContent)"
                                                        class="btn btn-sm" style="margin-top:10px;">📋 Copy
                                                        Script</button>

                                                    <hr style="margin:16px 0;border-color:var(--border);">
                                                    <h3 style="margin:0 0 10px">📋 Nginx Config (deploy trên Hetzner)
                                                    </h3>
                                                    <div class="log-box"
                                                        style="max-height:180px;color:#fde68a;font-size:11px;">
                                                        <pre style="margin:0;white-space:pre-wrap;">location ~* ^/hls/(.+)\.png$ {
    try_files /hls/$1.ts =404;
    types { }
    default_type image/png;
    add_header Cache-Control "public, max-age=31536000, immutable";
    add_header Access-Control-Allow-Origin "*";
}
location ~* ^/hls/.+\.m3u8$ {
    sub_filter '.ts' '.png';
    sub_filter_once off;
    add_header Cache-Control "no-cache";
    add_header Access-Control-Allow-Origin "*";
    default_type application/vnd.apple.mpegurl;
}</pre>
                                                    </div>
                                                    <button
                                                        onclick="navigator.clipboard.writeText(document.querySelectorAll('.log-box pre')[1].textContent)"
                                                        class="btn btn-sm" style="margin-top:10px;">📋 Copy Nginx
                                                        Config</button>
                                                </div>
                                            </div>

                                            <!-- ─── Bảng domains ─── -->
                                            <div class="cdn-card" style="margin-bottom:20px;">
                                                <h3>🌐 Danh Sách CDN Domains (<%= domains.length %>)</h3>
                                                <% if(domains.length===0) { %>
                                                    <p style="color:var(--text-secondary);font-size:13px;">Chưa có
                                                        domain nào. Thêm thủ công bên trên.</p>
                                                    <% } else { %>
                                                        <table class="domains-table">
                                                            <thead>
                                                                <tr>
                                                                    <th>Domain</th>
                                                                    <th>Server</th>
                                                                    <th>CF Email</th>
                                                                    <th>API Token</th>
                                                                    <th>Status</th>
                                                                    <th>Ghi chú</th>
                                                                    <th style="width:160px">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% domains.forEach(d=> { %>
                                                                    <tr id="row-<%= d.id %>">
                                                                        <td>
                                                                            <a href="https://<%= d.domain %>"
                                                                                target="_blank"
                                                                                style="color:var(--primary);text-decoration:none;font-weight:500;">
                                                                                <%= d.domain %>
                                                                            </a>
                                                                        </td>
                                                                        <td
                                                                            style="font-size:12px;color:var(--text-secondary)">
                                                                            <%= d.server_label || '—' %>
                                                                        </td>
                                                                        <td style="font-size:12px">
                                                                            <%= d.cf_email ?
                                                                                d.cf_email.substring(0,24)+'…' : '—' %>
                                                                        </td>
                                                                        <td>
                                                                            <% if(d.cf_api_token) { %>
                                                                                <span
                                                                                    style="font-size:11px;color:#4ade80;">✓
                                                                                    Đã có</span>
                                                                                <% } else { %>
                                                                                    <span
                                                                                        style="font-size:11px;color:#f87171;">✗
                                                                                        Chưa có</span>
                                                                                    <% } %>
                                                                        </td>
                                                                        <td>
                                                                            <% if(d.is_active) { %>
                                                                                <span class="badge-active">Active</span>
                                                                                <% } else { %>
                                                                                    <span
                                                                                        class="badge-inactive">Inactive</span>
                                                                                    <% } %>
                                                                        </td>
                                                                        <td style="font-size:11px;color:var(--text-secondary);max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                                                            title="<%= d.note %>">
                                                                            <%= d.note || '' %>
                                                                        </td>
                                                                        <td>
                                                                            <div
                                                                                style="display:flex;gap:6px;flex-wrap:wrap;">
                                                                                <button class="btn-xs info"
                                                                                    onclick="testDomain(<%= d.id %>, this)">Test</button>
                                                                                <button class="btn-xs muted"
                                                                                    onclick="toggleDomain(<%= d.id %>, this)">
                                                                                    <%= d.is_active ? 'Tắt' : 'Bật' %>
                                                                                </button>
                                                                                <button class="btn-xs muted"
                                                                                    onclick="openEdit(<%= d.id %>)"
                                                                                    style="background:#7c3aed;color:#fff;">Sửa</button>
                                                                                <form method="POST"
                                                                                    action="/admin/cdn/<%= d.id %>/delete"
                                                                                    onsubmit="return confirm('Xóa domain này?')"
                                                                                    style="margin:0">
                                                                                    <button type="submit"
                                                                                        class="btn-xs danger">Xóa</button>
                                                                                </form>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <!-- Edit inline row (hidden) -->
                                                                    <tr id="edit-<%= d.id %>"
                                                                        style="display:none;background:var(--surface-2,#12122a)">
                                                                        <td colspan="7">
                                                                            <form method="POST"
                                                                                action="/admin/cdn/<%= d.id %>/edit"
                                                                                style="padding:10px 0;">
                                                                                <div class="form-row">
                                                                                    <div class="form-group">
                                                                                        <label>Label</label>
                                                                                        <input name="label"
                                                                                            value="<%= d.label %>"
                                                                                            placeholder="Label">
                                                                                    </div>
                                                                                    <div class="form-group">
                                                                                        <label>Server</label>
                                                                                        <select name="server_id">
                                                                                            <option value="">-- Chọn --
                                                                                            </option>
                                                                                            <% servers.forEach(s=> { %>
                                                                                                <option
                                                                                                    value="<%= s.id %>"
                                                                                                    <%=d.server_id==s.id?'selected':''
                                                                                                    %>><%= s.label %>
                                                                                                </option>
                                                                                                <% }) %>
                                                                                        </select>
                                                                                    </div>
                                                                                    <div class="form-group">
                                                                                        <label>CF API Token
                                                                                            (mới)</label>
                                                                                        <input name="cf_api_token"
                                                                                            placeholder="Để trống giữ nguyên">
                                                                                    </div>
                                                                                    <div class="form-group">
                                                                                        <label>CF Zone ID (nếu
                                                                                            biết)</label>
                                                                                        <input name="cf_zone_id"
                                                                                            value="<%= d.cf_zone_id %>"
                                                                                            placeholder="auto nếu để trống">
                                                                                    </div>
                                                                                </div>
                                                                                <div class="form-row">
                                                                                    <div class="form-group">
                                                                                        <label>Ghi chú</label>
                                                                                        <input name="note"
                                                                                            value="<%= d.note %>"
                                                                                            placeholder="Ghi chú">
                                                                                    </div>
                                                                                </div>
                                                                                <div style="display:flex;gap:10px;">
                                                                                    <button type="submit"
                                                                                        class="btn btn-primary btn-sm">Lưu</button>
                                                                                    <button type="button"
                                                                                        class="btn btn-sm"
                                                                                        onclick="closeEdit(<%= d.id %>)">Huỷ</button>
                                                                                </div>
                                                                            </form>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                            </tbody>
                                                        </table>
                                                        <% } %>
                                            </div>



                                                    <script>
                                                        function openEdit(id) {
                                                            document.getElementById('edit-' + id).style.display = '';
                                                        }
                                                        function closeEdit(id) {
                                                            document.getElementById('edit-' + id).style.display = 'none';
                                                        }

                                                        // Toggle domain active/inactive
                                                        async function toggleDomain(id, btn) {
                                                            const res = await fetch(`/admin/cdn/${id}/toggle`, { method: 'POST' });
                                                            const data = await res.json();
                                                            if (data.ok) {
                                                                const row = document.getElementById('row-' + id);
                                                                const badge = row.querySelector('[class^="badge-"]');
                                                                if (data.is_active) {
                                                                    badge.className = 'badge-active';
                                                                    badge.textContent = 'Active';
                                                                    btn.textContent = 'Tắt';
                                                                } else {
                                                                    badge.className = 'badge-inactive';
                                                                    badge.textContent = 'Inactive';
                                                                    btn.textContent = 'Bật';
                                                                }
                                                            }
                                                        }

                                                        // Test domain
                                                        async function testDomain(id, btn) {
                                                            btn.textContent = '...';
                                                            btn.disabled = true;
                                                            const res = await fetch(`/admin/api/cdn/${id}/test`, { method: 'POST' });
                                                            const data = await res.json();
                                                            btn.disabled = false;
                                                            btn.textContent = 'Test';
                                                            alert(data.message + (data.cf_ray ? `\nCF-Ray: ${data.cf_ray}` : ''));
                                                        }
                                                    </script>

                                                    <%- include('../partials/footer') %>