<%- include('../partials/header') %>

<div class="card">
  <div class="card-header">
    <div class="card-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Danh sách Tài khoản <span style="color:var(--text-muted);font-weight:400;font-size:13px;">(<%= total || users.length %>)</span>
    </div>
    <a href="/admin/users/add" class="btn btn-primary btn-sm">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Thêm Tài khoản
    </a>
  </div>

  <% if (users.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        </svg>
      </div>
      <div class="empty-state-text">Chưa có tài khoản nào</div>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Tài khoản</th>
            <th>Tên hiển thị</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th>Ngày tạo</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) {
            var initials = (u.display_name || u.username || '?').charAt(0).toUpperCase();
            var isAdmin = u.role === 'administrator';
          %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,<%= isAdmin ? '#8b5cf6,#6d28d9' : '#3b82f6,#1d4ed8' %>);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;">
                  <%= initials %>
                </div>
                <div>
                  <div style="font-weight:600;"><%= u.username %></div>
                  <div style="font-size:11.5px;color:var(--text-muted);">#<%= u.id %></div>
                </div>
              </div>
            </td>
            <td style="color:var(--text-secondary);"><%= u.display_name || '—' %></td>
            <td>
              <% if (isAdmin) { %>
                <span class="badge badge-live"><span class="badge-dot"></span>Admin</span>
              <% } else { %>
                <span class="badge badge-processing"><span class="badge-dot"></span>Uploader</span>
              <% } %>
            </td>
            <td>
              <% if (u.is_active) { %>
                <span class="badge badge-ready"><span class="badge-dot"></span>Active</span>
              <% } else { %>
                <span class="badge badge-die"><span class="badge-dot"></span>Disabled</span>
              <% } %>
            </td>
            <td style="color:var(--text-muted);font-size:12px;white-space:nowrap;"><%= u.created_at %></td>
            <td>
              <div class="btn-group">
                <a href="/admin/users/<%= u.id %>/edit" class="btn btn-ghost btn-sm btn-icon" title="Sửa">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </a>
                <% if (u.id !== currentUser.id) { %>
                  <form action="/admin/users/<%= u.id %>/delete" method="POST" class="delete-form" data-name="<%= u.username %>" style="margin:0;">
                    <button type="submit" class="btn btn-ghost btn-sm btn-icon" title="Xoá" style="color:var(--danger);">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                    </button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  document.querySelectorAll('.delete-form').forEach(function (f) {
    f.addEventListener('submit', function (e) {
      if (!confirm('Bạn có chắc muốn xoá tài khoản: ' + this.dataset.name + '?')) e.preventDefault();
    });
  });
</script>

<% var paginationBase = '/admin/users'; %>
<%- include('../partials/pagination') %>

<%- include('../partials/footer') %>

