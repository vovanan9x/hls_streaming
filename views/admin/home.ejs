<%- include('../partials/header') %>

    <style>
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 22px 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            transition: var(--transition);
        }

        .stat-card:hover {
            border-color: var(--border-light);
            transform: translateY(-2px);
        }

        .stat-card.accent {
            border-left: 3px solid var(--accent);
        }

        .stat-card.green {
            border-left: 3px solid var(--success);
        }

        .stat-card.yellow {
            border-left: 3px solid var(--warning);
        }

        .stat-card.red {
            border-left: 3px solid var(--danger);
        }

        .stat-card.blue {
            border-left: 3px solid var(--info);
        }

        .stat-icon {
            font-size: 28px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1;
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .section-title {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 14px;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border-color);
        }
    </style>

    <!-- Thống kê của tôi -->
    <div class="section-title">📊 Video của tôi (<%= currentUser.display_name || currentUser.username %>)</div>
    <div class="stat-grid">
        <div class="stat-card accent">
            <span class="stat-icon">🎞️</span>
            <span class="stat-value">
                <%= stats.myTotal %>
            </span>
            <span class="stat-label">Tổng video đã upload</span>
        </div>
        <div class="stat-card green">
            <span class="stat-icon">✅</span>
            <span class="stat-value">
                <%= stats.myReady %>
            </span>
            <span class="stat-label">Video sẵn sàng phát</span>
        </div>
        <div class="stat-card yellow">
            <span class="stat-icon">⚙️</span>
            <span class="stat-value">
                <%= stats.myProcessing %>
            </span>
            <span class="stat-label">Đang xử lí</span>
        </div>
    </div>

    <!-- Thống kê toàn hệ thống -->
    <div class="section-title">🌐 Toàn hệ thống</div>
    <div class="stat-grid">
        <div class="stat-card accent">
            <span class="stat-icon">📹</span>
            <span class="stat-value">
                <%= stats.totalVideos %>
            </span>
            <span class="stat-label">Tổng video (tất cả user)</span>
        </div>
        <div class="stat-card green">
            <span class="stat-icon">▶️</span>
            <span class="stat-value">
                <%= stats.totalReady %>
            </span>
            <span class="stat-label">Video sẵn sàng</span>
        </div>
        <div class="stat-card yellow">
            <span class="stat-icon">⏳</span>
            <span class="stat-value">
                <%= stats.totalProcessing %>
            </span>
            <span class="stat-label">Đang xử lí</span>
        </div>
        <div class="stat-card red">
            <span class="stat-icon">❌</span>
            <span class="stat-value">
                <%= stats.totalError %>
            </span>
            <span class="stat-label">Lỗi</span>
        </div>
        <% if (stats.totalUsers !==null) { %>
            <div class="stat-card blue">
                <span class="stat-icon">👥</span>
                <span class="stat-value">
                    <%= stats.totalUsers %>
                </span>
                <span class="stat-label">Tài khoản</span>
            </div>
            <div class="stat-card<%= stats.liveServers > 0 ? ' green' : ' red' %>">
                <span class="stat-icon">🖥️</span>
                <span class="stat-value">
                    <%= stats.liveServers %>/<%= stats.totalServers %>
                </span>
                <span class="stat-label">Server hoạt động</span>
            </div>
            <% } %>
    </div>

    <!-- Video mới nhất của tôi -->
    <% if (recentVideos.length> 0) { %>
        <div class="section-title">🕐 Upload gần đây (của tôi)</div>
        <div class="card" style="padding:0;">
            <table style="margin:0">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Server</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% recentVideos.forEach(function(v) { %>
                        <tr>
                            <td style="font-weight:500">
                                <%= v.title %>
                            </td>
                            <td style="color:var(--text-muted);font-size:13px">
                                <%= v.server_label || 'Local' %>
                            </td>
                            <td>
                                <% if (v.status==='ready' ) { %>
                                    <span class="badge badge-ready">READY</span>
                                    <% } else if (v.status==='processing' ) { %>
                                        <span class="badge badge-processing">PROCESSING (<%= v.progress || 0 %>%)</span>
                                        <% } else { %>
                                            <span class="badge badge-error">LỖI</span>
                                            <% } %>
                            </td>
                            <td style="color:var(--text-muted);font-size:13px;white-space:nowrap">
                                <%= v.created_at %>
                            </td>
                            <td>
                                <a href="/admin/videos" class="btn btn-ghost btn-sm">Xem →</a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>

            <%- include('../partials/footer') %>