<%- include('../partials/header') %>

<div class="card">
  <div class="card-header">
    <div class="card-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
      </svg>
      Danh sách Server <span style="color:var(--text-muted);font-weight:400;font-size:13px;">(<%= servers.length %>)</span>
    </div>
    <div class="btn-group">
      <button id="ping-all-btn" class="btn btn-ghost btn-sm" onclick="pingAll()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;">
          <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Ping All
      </button>
      <a href="/admin/servers/add" class="btn btn-primary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Thêm Server
      </a>
    </div>
  </div>

  <% if (servers.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
        </svg>
      </div>
      <div class="empty-state-text">Chưa có server nào</div>
      <div class="empty-state-hint">Thêm server SFTP hoặc Cloudflare R2 để có thể upload video</div>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Label</th>
            <th>Kết nối</th>
            <th>Storage Path</th>
            <th>Trạng thái</th>
            <th>Dung lượng</th>
            <th>Kiểm tra lần cuối</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% servers.forEach(function(s) { %>
          <tr data-server-id="<%= s.id %>">
            <td>
              <div style="font-weight:600;"><%= s.label %></div>
              <div style="font-size:11.5px;color:var(--text-muted);margin-top:3px;display:flex;gap:10px;flex-wrap:wrap;">
                <span style="color:var(--accent);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px;vertical-align:middle;"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                  <%= s.video_count || 0 %> video
                </span>
                <span style="color:var(--success);">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px;vertical-align:middle;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  <%= s.cdn_count || 0 %> CDN
                </span>
                <% if (s.total_bytes > 0) { %>
                <span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px;vertical-align:middle;"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                  <%= (s.total_bytes/1024/1024/1024).toFixed(1) %> GB
                </span>
                <% } %>
              </div>
            </td>
            <td style="font-family:monospace;font-size:12.5px;color:var(--text-secondary);">
              <%= s.ip %>:<%= s.port %>
              <div style="font-size:11px;color:var(--text-muted);margin-top:2px;"><%= s.username %></div>
            </td>
            <td style="font-family:monospace;font-size:12px;color:var(--text-muted);"><%= s.storage_path %></td>
            <td>
              <% if (s.status === 'live') { %>
                <span class="badge badge-live status-badge" id="status-<%= s.id %>" data-status="live"><span class="badge-dot"></span>Live</span>
              <% } else if (s.status === 'die') { %>
                <span class="badge badge-die status-badge" id="status-<%= s.id %>" data-status="die"><span class="badge-dot"></span>Offline</span>
              <% } else { %>
                <span class="badge badge-unknown status-badge" id="status-<%= s.id %>" data-status="unknown"><span class="badge-dot"></span>Unknown</span>
              <% } %>
            </td>
            <td id="disk-<%= s.id %>" style="font-size:12px;color:var(--text-muted);white-space:nowrap;">
              <span style="color:var(--text-muted);">—</span>
            </td>
            <td class="last-checked" id="checked-<%= s.id %>" style="color:var(--text-muted);font-size:12px;white-space:nowrap;">
              <%= s.last_checked || 'Chưa kiểm tra' %>
            </td>
            <td>
              <div class="btn-group">
                <button class="btn btn-ghost btn-sm btn-icon ping-btn" data-id="<%= s.id %>"
                  title="Kiểm tra kết nối" onclick="pingServer(<%= s.id %>, this)">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                </button>
                <button class="btn btn-ghost btn-sm btn-icon" title="Nginx Config"
                  onclick="showNginxConfig(<%= s.id %>, '<%= s.label %>')">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                </button>
                <a href="/admin/servers/<%= s.id %>/edit" class="btn btn-ghost btn-sm btn-icon" title="Sửa">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </a>
                <form action="/admin/servers/<%= s.id %>/delete" method="POST" class="delete-form" data-name="<%= s.label %>" style="margin:0;">
                  <button type="submit" class="btn btn-ghost btn-sm btn-icon" title="Xoá" style="color:var(--danger);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<p style="color:var(--text-muted);font-size:12px;margin-top:-8px;margin-bottom:16px;padding:0 2px;">
  Trạng thái SFTP được kiểm tra tự động mỗi 1 phút. Nhấn
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;vertical-align:middle;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
  để kiểm tra thủ công,
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;vertical-align:middle;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
  để xem nginx config.
</p>

<!-- Nginx Modal -->
<div class="modal-backdrop" id="nginx-modal">
  <div class="modal" style="max-width:760px;width:90%;max-height:85vh;display:flex;flex-direction:column;">
    <div class="modal-header" style="flex-shrink:0;">
      <div class="modal-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Nginx Config — <span id="nginx-server-label"></span>
      </div>
      <button class="modal-close" onclick="document.getElementById('nginx-modal').classList.remove('open')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <pre id="nginx-config-text" style="flex:1;overflow:auto;max-height:50vh;">Loading...</pre>
    <div class="modal-footer" style="flex-shrink:0;">
      <button onclick="copyNginxConfig()" class="btn btn-primary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copy
      </button>
      <button onclick="document.getElementById('nginx-modal').classList.remove('open')" class="btn btn-ghost btn-sm">Đóng</button>
    </div>
  </div>
</div>

<style>
  .ping-btn.loading { pointer-events:none; opacity:.5; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  // Delete confirm
  document.querySelectorAll('.delete-form').forEach(function (f) {
    f.addEventListener('submit', function (e) {
      if (!confirm('Bạn có chắc muốn xoá server: ' + this.dataset.name + '?')) e.preventDefault();
    });
  });

  function updateStatusBadge(id, status) {
    var badge = document.getElementById('status-' + id);
    if (!badge) return;
    badge.className = 'badge status-badge';
    if (status === 'live') {
      badge.classList.add('badge-live');
      badge.innerHTML = '<span class="badge-dot"></span>Live';
    } else if (status === 'die') {
      badge.classList.add('badge-die');
      badge.innerHTML = '<span class="badge-dot"></span>Offline';
    } else if (status === 'r2') {
      badge.classList.add('badge-ready');
      badge.innerHTML = '<span class="badge-dot"></span>CDN';
    } else {
      badge.classList.add('badge-unknown');
      badge.innerHTML = '<span class="badge-dot"></span>Unknown';
    }
  }

  function renderDisk(id, disk) {
    var el = document.getElementById('disk-' + id);
    if (!el || !disk) return;
    var pct = parseInt(disk.percent) || 0;
    var color = pct > 90 ? '#ef4444' : pct > 70 ? '#f59e0b' : '#22c55e';
    el.innerHTML =
      '<div style="min-width:120px;">' +
        '<div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px;">' +
          '<span style="color:' + color + ';font-weight:600;">' + disk.used + '/' + disk.total + '</span>' +
          '<span style="color:' + color + ';">' + disk.percent + '</span>' +
        '</div>' +
        '<div style="height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;">' +
          '<div style="height:4px;background:' + color + ';border-radius:2px;width:' + pct + '%;transition:width 0.3s;"></div>' +
        '</div>' +
        '<div style="font-size:10px;color:var(--text-muted);margin-top:2px;">Trống: ' + disk.available + '</div>' +
      '</div>';
  }

  function pingServer(id, btn) {
    if (btn) {
      btn.classList.add('loading');
      btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;animation:spin 1s linear infinite;"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>';
    }
    fetch('/admin/api/servers/' + id + '/ping', { method: 'POST' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (btn) { btn.classList.remove('loading'); btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>'; }
        updateStatusBadge(id, data.status);
        renderDisk(id, data.disk);
        var checked = document.getElementById('checked-' + id);
        if (checked && data.last_checked) checked.textContent = data.last_checked;
        showToast(data.ok ? 'success' : 'error', data.message);
      })
      .catch(function (e) {
        if (btn) { btn.classList.remove('loading'); btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>'; }
        showToast('error', 'Lỗi kết nối: ' + e.message);
      });
  }

  function pingAll() {
    var allBtn = document.getElementById('ping-all-btn');
    var btns = document.querySelectorAll('.ping-btn');
    if (allBtn) { allBtn.disabled = true; allBtn.textContent = '⏳ Đang ping...'; }
    var ids = Array.from(btns).map(function (b) { return parseInt(b.dataset.id); });
    var pending = ids.length;
    if (!pending) return;
    ids.forEach(function (id) {
      var btn = document.querySelector('.ping-btn[data-id="' + id + '"]');
      pingServerSilent(id, btn, function () {
        pending--;
        if (pending === 0 && allBtn) {
          allBtn.disabled = false; allBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Ping All';
          showToast('success', 'Đã kiểm tra toàn bộ ' + ids.length + ' server!');
        }
      });
    });
  }

  function pingServerSilent(id, btn, done) {
    if (btn) { btn.classList.add('loading'); btn.innerHTML = ''; }
    fetch('/admin/api/servers/' + id + '/ping', { method: 'POST' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (btn) { btn.classList.remove('loading'); btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>'; }
        updateStatusBadge(id, data.status);
        renderDisk(id, data.disk);
        var checked = document.getElementById('checked-' + id);
        if (checked && data.last_checked) checked.textContent = data.last_checked;
        if (done) done();
      })
      .catch(function () {
        if (btn) { btn.classList.remove('loading'); btn.innerHTML = ''; }
        if (done) done();
      });
  }

  function showNginxConfig(id, label) {
    document.getElementById('nginx-server-label').textContent = label;
    document.getElementById('nginx-config-text').textContent = 'Loading...';
    document.getElementById('nginx-modal').classList.add('open');
    fetch('/admin/api/servers/' + id + '/nginx-config')
      .then(function (r) { return r.text(); })
      .then(function (text) { document.getElementById('nginx-config-text').textContent = text; })
      .catch(function (e) { document.getElementById('nginx-config-text').textContent = 'Lỗi: ' + e.message; });
  }

  function copyNginxConfig() {
    var text = document.getElementById('nginx-config-text').textContent;
    navigator.clipboard.writeText(text).then(function () { showToast('success', 'Nginx config đã được copy!'); });
  }

  document.getElementById('nginx-modal').addEventListener('click', function (e) {
    if (e.target === this) this.classList.remove('open');
  });

  // Tự động ping tất cả server khi trang load
  if (document.querySelectorAll('.ping-btn').length > 0) {
    pingAll();
  }
</script>

<%- include('../partials/footer') %>