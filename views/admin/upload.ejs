<%- include('../partials/header') %>

<% if (error) { %>
  <div class="alert alert-error">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <%= error %>
  </div>
<% } %>
<% if (success) { %>
  <div class="alert alert-success">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <%= success %>
  </div>
<% } %>

<% if (noServers) { %>
  <div class="card" style="text-align:center;padding:56px 24px;">
    <div style="width:56px;height:56px;margin:0 auto 20px;background:rgba(139,92,246,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:26px;height:26px;color:var(--accent);">
        <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
      </svg>
    </div>
    <div style="font-size:18px;font-weight:700;margin-bottom:8px;">Chưa có server lưu trữ</div>
    <p style="color:var(--text-muted);font-size:13px;max-width:400px;margin:0 auto 20px;">Thêm ít nhất một server SFTP để bắt đầu upload video.</p>
    <a href="/admin/servers/add" class="btn btn-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Thêm Server ngay
    </a>
  </div>
<% } else { %>

<form action="/admin/upload" method="POST" enctype="multipart/form-data" id="upload-form">
  <input type="hidden" name="upload_type" id="upload_type" value="local">

  <div class="card">
    <div class="card-header">
      <div class="card-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        Upload Video
      </div>
    </div>

    <!-- Row 1: Title + IDAH -->
    <div style="display:grid;grid-template-columns:1fr auto;gap:14px;margin-bottom:14px;align-items:start;">
      <div class="form-group" style="margin:0;">
        <label class="form-label">Tiêu đề *</label>
        <input type="text" name="title" class="form-input" placeholder="Nhập tiêu đề video..." required>
      </div>
      <div class="form-group" style="margin:0;min-width:160px;">
        <label class="form-label">
          IDAH
          <span style="color:var(--text-muted);font-weight:400;font-size:10px;text-transform:none;">(ID tuỳ chỉnh)</span>
        </label>
        <input type="text" name="idah" class="form-input" placeholder="Tuỳ chọn...">
      </div>
    </div>

    <!-- Row 2: Mô tả -->
    <div class="form-group" style="margin-bottom:16px;">
      <label class="form-label">Mô tả</label>
      <input type="text" name="description" class="form-input" placeholder="Mô tả ngắn (tuỳ chọn)...">
    </div>

    <!-- Source tabs -->
    <div class="tabs" style="margin-bottom:14px;">
      <button type="button" class="tab-btn active" data-tab="local">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Local File
      </button>
      <button type="button" class="tab-btn" data-tab="remote">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Remote URL
      </button>
      <button type="button" class="tab-btn" data-tab="gdrive">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Google Drive
      </button>
    </div>

    <!-- Tab: local -->
    <div id="tab-local" class="tab-content active">
      <div class="dropzone" id="video-dropzone">
        <svg class="dropzone-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <div class="dropzone-text">Kéo thả hoặc <strong>click để chọn file</strong></div>
        <div class="dropzone-hint">MP4, MKV, AVI, MOV, WEBM — tối đa 10GB</div>
      </div>
      <input type="file" name="video" id="video-file" accept=".mp4,.mkv,.avi,.mov,.webm" style="display:none;">
      <div id="file-preview" class="file-preview">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px;color:var(--accent);flex-shrink:0;"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        <span class="file-name"></span>
        <span class="file-size"></span>
        <button type="button" class="file-remove" onclick="removeFile()">✕</button>
      </div>
    </div>

    <!-- Tab: remote -->
    <div id="tab-remote" class="tab-content">
      <div class="form-group" style="margin:0;">
        <input type="url" name="remote_url" class="form-input" placeholder="https://example.com/video.mp4">
        <div class="form-hint">Đường dẫn trực tiếp tới file MP4, MKV...</div>
      </div>
    </div>

    <!-- Tab: gdrive -->
    <div id="tab-gdrive" class="tab-content">
      <div class="form-group" style="margin:0;">
        <input type="text" name="gdrive_url" class="form-input" placeholder="https://drive.google.com/file/d/... hoặc File ID">
        <div class="form-hint">Paste link Google Drive hoặc chỉ File ID — file phải public (Anyone with link)</div>
      </div>
    </div>

    <!-- Upload progress overlay (hidden by default) -->

    <div style="border-top:1px solid var(--border);margin:20px 0 18px;"></div>

    <!-- Settings row -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;align-items:start;">

      <!-- Server -->
      <div class="form-group" style="margin:0;">
        <label class="form-label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          Server lưu trữ *
        </label>
        <select name="server_id" id="server-select" class="form-select" required>
          <option value="auto">⚡ Tự động chọn</option>
          <% servers.forEach(function(s) { %>
            <option value="<%= s.id %>"><%= s.label %></option>
          <% }) %>
        </select>
        <div id="auto-server-hint" style="margin-top:5px;font-size:11.5px;color:var(--accent);display:none;">
          Sẽ chọn: <strong id="auto-server-name">...</strong>
        </div>
        <div class="form-hint"><a href="/admin/servers/add" style="color:var(--accent);">+ Thêm server</a></div>
      </div>

      <!-- Quality -->
      <div class="form-group" style="margin:0;">
        <label class="form-label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          Chất lượng Render
        </label>
        <div style="display:flex;gap:8px;margin-top:6px;" id="quality-group">
          <label class="quality-label" id="ql-sd">
            <input type="radio" name="qualities" value="sd" class="quality-rb" checked>
            <span><strong style="font-size:13px;">SD</strong><small style="color:var(--text-muted);display:block;font-size:10.5px;">720p · Nhanh</small></span>
          </label>
          <label class="quality-label" id="ql-hd">
            <input type="radio" name="qualities" value="hd" class="quality-rb">
            <span><strong style="font-size:13px;">HD</strong><small style="color:var(--text-muted);display:block;font-size:10.5px;">Gốc · Cao</small></span>
          </label>
        </div>
      </div>

      <!-- Visibility + Thumbnail -->
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group" style="margin:0;">
          <label class="form-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Quyền xem
          </label>
          <div style="display:flex;gap:14px;margin-top:6px;">
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;">
              <input type="radio" name="visibility" value="public" checked style="accent-color:var(--accent);">
              🌐 Public
            </label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;">
              <input type="radio" name="visibility" value="private" style="accent-color:var(--accent);">
              🔒 Private
            </label>
          </div>
        </div>

        <div class="form-group" style="margin:0;">
          <label class="form-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Thumbnail
          </label>
          <div class="thumb-options" style="display:flex;gap:6px;margin-top:6px;">
            <div class="thumb-option active" id="thumb-opt-auto" style="flex:1;">
              <input type="radio" name="thumb_mode" value="auto" checked id="thumb-auto">
              <label for="thumb-auto" style="font-size:12px;">🤖 Tự động</label>
            </div>
            <div class="thumb-option" id="thumb-opt-upload" style="flex:1;">
              <input type="radio" name="thumb_mode" value="upload" id="thumb-upload">
              <label for="thumb-upload" style="font-size:12px;">📁 Upload</label>
            </div>
          </div>
          <div id="thumb-upload-area" style="display:none;margin-top:8px;">
            <input type="file" name="thumbnail_file" class="form-input" accept=".png,.jpg,.jpeg,.webp">
          </div>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div style="margin-top:22px;">
      <button type="submit" class="btn btn-primary" id="submit-btn" style="padding:12px 28px;font-size:14px;width:100%;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Upload & Xử lý Video
      </button>
    </div>
  </div>
</form>

<!-- ── Upload Progress Overlay ── -->
<div id="upload-overlay" style="display:none;opacity:0;position:fixed;inset:0;z-index:10000;background:rgba(10,10,20,0.88);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);align-items:center;justify-content:center;transition:opacity 0.3s;">
  <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:18px;padding:40px 48px;min-width:420px;max-width:560px;width:90%;text-align:center;box-shadow:0 24px 80px rgba(0,0,0,0.6);">

    <!-- Icon + Phase -->
    <div style="margin-bottom:20px;">
      <div style="width:64px;height:64px;margin:0 auto 14px;background:rgba(139,92,246,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width:30px;height:30px;color:var(--accent);">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
      </div>
      <div id="ov-phase" style="font-size:13.5px;color:var(--text-secondary);">Đang gửi file lên server...</div>
    </div>

    <!-- Big percentage -->
    <div style="font-size:56px;font-weight:800;color:var(--text-primary);line-height:1;margin-bottom:6px;letter-spacing:-2px;">
      <span id="ov-pct">0</span><span style="font-size:28px;font-weight:700;color:var(--accent);">%</span>
    </div>

    <!-- Progress bar -->
    <div style="background:rgba(255,255,255,0.07);border-radius:100px;height:8px;margin:18px 0 22px;overflow:hidden;">
      <div id="ov-bar-fill" style="height:100%;width:0%;border-radius:100px;background:linear-gradient(90deg,var(--accent),#a78bfa);transition:width 0.4s ease;"></div>
    </div>

    <!-- File name -->
    <div id="ov-filename" style="font-size:13px;color:var(--text-primary);font-weight:600;margin-bottom:18px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;"></div>

    <!-- Stats row -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
      <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:12px 8px;">
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.5px;">Tốc độ</div>
        <div id="ov-speed" style="font-size:15px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:12px 8px;">
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.5px;">Còn lại</div>
        <div id="ov-eta" style="font-size:15px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
      <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:12px 8px;">
        <div style="font-size:10px;color:var(--text-muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.5px;">Đã gửi</div>
        <div id="ov-transferred" style="font-size:12px;font-weight:700;color:var(--text-primary);white-space:nowrap;">0 B / —</div>
      </div>
    </div>

    <div style="margin-top:18px;font-size:11.5px;color:var(--text-muted);">Vui lòng không tắt trang trong quá trình upload</div>
  </div>
</div>

<% } %>


<script>
(function () {
  // Quality labels
  var LS_KEY = 'hls_upload_quality';
  function styleLabels() {
    document.querySelectorAll('.quality-rb').forEach(function (rb) {
      var l = rb.closest('.quality-label');
      if (!l) return;
      l.style.borderColor = rb.checked ? 'var(--accent)' : 'var(--border)';
      l.style.background = rb.checked ? 'var(--accent-dim)' : 'var(--bg-input)';
    });
  }
  var saved = localStorage.getItem(LS_KEY) || 'sd';
  document.querySelectorAll('.quality-rb').forEach(function (rb) { rb.checked = (rb.value === saved); });
  styleLabels();
  document.querySelectorAll('.quality-rb').forEach(function (rb) {
    rb.addEventListener('change', function () { localStorage.setItem(LS_KEY, rb.value); styleLabels(); });
  });

  // Thumbnail options
  var thumbOpts = document.querySelectorAll('.thumb-option');
  thumbOpts.forEach(function (opt) {
    opt.addEventListener('click', function () {
      thumbOpts.forEach(function (o) { o.classList.remove('active'); });
      opt.classList.add('active');
      var radio = opt.querySelector('input[type="radio"]');
      if (radio) radio.checked = true;
      document.getElementById('thumb-upload-area').style.display = (radio && radio.value === 'upload') ? 'block' : 'none';
    });
  });

  // Server select + auto hint
  var LS_SERVER = 'hls_last_server';
  var serverSel = document.querySelector('select[name="server_id"]');
  if (serverSel) {
    var savedSrv = localStorage.getItem(LS_SERVER);
    if (savedSrv) serverSel.value = savedSrv;
    serverSel.addEventListener('change', function () { localStorage.setItem(LS_SERVER, this.value); updateAutoHint(); });
    updateAutoHint();
  }
  function updateAutoHint() {
    var hint = document.getElementById('auto-server-hint');
    var name = document.getElementById('auto-server-name');
    if (!hint || !name || !serverSel) return;
    if (serverSel.value === 'auto') {
      hint.style.display = 'block';
      name.textContent = 'đang tìm...';
      fetch('/admin/api/servers/least-loaded').then(function (r) { return r.json(); }).then(function (d) {
        name.textContent = d.ok ? d.server.label + ' (' + d.server.video_count + ' video)' : 'không tìm thấy';
      });
    } else {
      hint.style.display = 'none';
    }
  }

  // XHR Upload with full-screen progress overlay
  var form = document.getElementById('upload-form');
  var submitBtn = document.getElementById('submit-btn');

  function fmtBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1024 / 1024).toFixed(1) + ' MB';
  }
  function fmtTime(sec) {
    if (!isFinite(sec) || sec < 0) return '--';
    if (sec < 60) return Math.ceil(sec) + 's';
    if (sec < 3600) return Math.floor(sec / 60) + 'm ' + (Math.ceil(sec % 60)) + 's';
    return Math.floor(sec / 3600) + 'h ' + Math.floor((sec % 3600) / 60) + 'm';
  }

  function showUploadOverlay(fileName) {
    var ov = document.getElementById('upload-overlay');
    document.getElementById('ov-filename').textContent = fileName;
    document.getElementById('ov-pct').textContent = '0';
    document.getElementById('ov-bar-fill').style.width = '0%';
    document.getElementById('ov-bar-fill').style.background = 'linear-gradient(90deg, var(--accent), #a78bfa)';
    document.getElementById('ov-speed').textContent = '—';
    document.getElementById('ov-eta').textContent = '—';
    document.getElementById('ov-transferred').textContent = '0 B / —';
    document.getElementById('ov-phase').textContent = 'Đang gửi file lên server...';
    document.getElementById('ov-phase').style.color = 'var(--text-secondary)';
    ov.style.display = 'flex';
    requestAnimationFrame(function () { ov.style.opacity = '1'; });
  }

  function updateOverlay(pct, loaded, total, speed, eta, phase) {
    document.getElementById('ov-pct').textContent = pct;
    document.getElementById('ov-bar-fill').style.width = pct + '%';
    if (phase === 'processing') {
      document.getElementById('ov-bar-fill').style.background = 'linear-gradient(90deg, #34d399, #059669)';
    }
    document.getElementById('ov-speed').textContent = speed;
    document.getElementById('ov-eta').textContent = eta;
    document.getElementById('ov-transferred').textContent = fmtBytes(loaded) + ' / ' + fmtBytes(total);
    if (phase === 'processing') {
      document.getElementById('ov-phase').textContent = '⚙️ Server đang xử lý & encode...';
      document.getElementById('ov-phase').style.color = '#34d399';
    }
  }

  // Indeterminate pulse animation for remote downloads
  var pulseInterval = null;
  function startPulseAnimation() {
    var pct = 0;
    var direction = 1;
    pulseInterval = setInterval(function () {
      pct += direction * 1.5;
      if (pct >= 85) { pct = 85; direction = -1; }
      if (pct <= 10) { pct = 10; direction = 1; }
      document.getElementById('ov-bar-fill').style.width = pct + '%';
    }, 80);
  }
  function stopPulseAnimation() {
    if (pulseInterval) { clearInterval(pulseInterval); pulseInterval = null; }
  }

  if (form) {
    form.addEventListener('submit', function (e) {
      var uploadType = document.getElementById('upload_type').value;

      if (uploadType === 'local') {
        // ── Local file upload with real progress ──
        var fileInput = document.getElementById('video-file');
        if (!fileInput || !fileInput.files || fileInput.files.length === 0) return;
        e.preventDefault();

        var file = fileInput.files[0];
        showUploadOverlay(file.name);
        submitBtn.disabled = true;

        var fd = new FormData(form);
        var xhr = new XMLHttpRequest();
        var startTime = Date.now();
        var lastLoaded = 0;
        var lastTime = startTime;

        xhr.upload.addEventListener('progress', function (ev) {
          if (!ev.lengthComputable) return;
          var now = Date.now();
          var dt = (now - lastTime) / 1000;
          var pct = Math.round((ev.loaded / ev.total) * 100);
          var speed = dt > 0.2 ? (ev.loaded - lastLoaded) / dt : 0;
          var remaining = speed > 0 ? (ev.total - ev.loaded) / speed : Infinity;
          lastLoaded = ev.loaded;
          lastTime = now;
          var speedStr = speed > 0 ? fmtBytes(speed) + '/s' : '—';
          var etaStr = fmtTime(remaining);
          updateOverlay(pct, ev.loaded, ev.total, speedStr, etaStr, pct >= 100 ? 'processing' : 'uploading');
        });

        xhr.addEventListener('load', function () {
          document.open(); document.write(xhr.responseText); document.close();
        });

        xhr.addEventListener('error', function () {
          document.getElementById('upload-overlay').style.opacity = '0';
          setTimeout(function () { document.getElementById('upload-overlay').style.display = 'none'; }, 300);
          submitBtn.disabled = false;
          showToast('error', 'Lỗi kết nối! Kiểm tra file và thử lại.');
        });

        xhr.open('POST', '/admin/upload');
        xhr.send(fd);

      } else if (uploadType === 'remote' || uploadType === 'gdrive') {
        // ── Remote URL / Google Drive — poll server for download progress ──
        var urlInput = uploadType === 'remote'
          ? form.querySelector('input[name="remote_url"]')
          : form.querySelector('input[name="gdrive_url"]');
        var urlVal = urlInput ? urlInput.value.trim() : '';
        if (!urlVal) return; // let HTML validation handle it

        e.preventDefault();
        var displayName = uploadType === 'gdrive' ? 'Google Drive file' : urlVal.split('/').pop().split('?')[0] || 'remote file';
        var phaseText = uploadType === 'gdrive'
          ? '📥 Đang tải file từ Google Drive...'
          : '📥 Đang tải file từ Remote URL...';

        // Generate unique trackId for progress polling
        var trackId = 'dl_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6);

        showUploadOverlay(displayName);
        document.getElementById('ov-phase').textContent = phaseText;
        document.getElementById('ov-phase').style.color = '#facc15';
        document.getElementById('ov-pct').textContent = '0';
        document.getElementById('ov-speed').textContent = '...';
        document.getElementById('ov-eta').textContent = '...';
        document.getElementById('ov-transferred').textContent = 'đang kết nối...';
        startPulseAnimation();
        submitBtn.disabled = true;

        var fd2 = new FormData(form);
        fd2.append('download_track_id', trackId);
        var xhr2 = new XMLHttpRequest();
        var pollDone = false;

        // Poll download progress from server
        var progressPoll = setInterval(function () {
          if (pollDone) return;
          var pxhr = new XMLHttpRequest();
          pxhr.open('GET', '/admin/upload/download-progress?trackId=' + encodeURIComponent(trackId));
          pxhr.onload = function () {
            if (pollDone) return;
            try {
              var d = JSON.parse(pxhr.responseText);
              if (d.percent >= 0 && d.total > 0) {
                stopPulseAnimation();
                document.getElementById('ov-pct').textContent = d.percent;
                document.getElementById('ov-bar-fill').style.width = Math.min(d.percent, 100) + '%';
                var speedStr = d.speed > 0 ? fmtBytes(d.speed) + '/s' : '...';
                var etaStr = d.eta > 0 ? fmtTime(d.eta) : '...';
                document.getElementById('ov-speed').textContent = speedStr;
                document.getElementById('ov-eta').textContent = etaStr;
                document.getElementById('ov-transferred').textContent = fmtBytes(d.downloaded) + ' / ' + fmtBytes(d.total);
                if (d.percent >= 100) {
                  document.getElementById('ov-phase').textContent = '⚙️ Đang xử lý & thêm vào hàng đợi...';
                  document.getElementById('ov-phase').style.color = '#34d399';
                  document.getElementById('ov-bar-fill').style.background = 'linear-gradient(90deg, #34d399, #059669)';
                }
              }
            } catch (ex) { /* ignore parse error */ }
          };
          pxhr.send();
        }, 800);

        xhr2.addEventListener('load', function () {
          pollDone = true;
          clearInterval(progressPoll);
          stopPulseAnimation();
          document.open(); document.write(xhr2.responseText); document.close();
        });

        xhr2.addEventListener('error', function () {
          pollDone = true;
          clearInterval(progressPoll);
          stopPulseAnimation();
          document.getElementById('upload-overlay').style.opacity = '0';
          setTimeout(function () { document.getElementById('upload-overlay').style.display = 'none'; }, 300);
          submitBtn.disabled = false;
          showToast('error', 'Lỗi kết nối! Kiểm tra URL và thử lại.');
        });

        xhr2.open('POST', '/admin/upload');
        xhr2.send(fd2);
      }
    });
  }

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
      document.querySelectorAll('.tab-content').forEach(function (c) { c.classList.remove('active'); });
      btn.classList.add('active');
      var tc = document.getElementById('tab-' + tab);
      if (tc) tc.classList.add('active');
      document.getElementById('upload_type').value = tab;
    });
  });

  // Dropzone
  var dz = document.getElementById('video-dropzone');
  var fi = document.getElementById('video-file');
  if (dz && fi) {
    dz.addEventListener('click', function () { fi.click(); });
    dz.addEventListener('dragover', function (e) { e.preventDefault(); dz.classList.add('dragover'); });
    dz.addEventListener('dragleave', function () { dz.classList.remove('dragover'); });
    dz.addEventListener('drop', function (e) {
      e.preventDefault(); dz.classList.remove('dragover');
      if (e.dataTransfer.files[0]) { fi.files = e.dataTransfer.files; showPreview(e.dataTransfer.files[0]); }
    });
    fi.addEventListener('change', function () { if (fi.files[0]) showPreview(fi.files[0]); });
  }
  function showPreview(f) {
    var prev = document.getElementById('file-preview');
    if (!prev) return;
    prev.classList.add('active');
    prev.querySelector('.file-name').textContent = f.name;
    prev.querySelector('.file-size').textContent = (f.size / 1024 / 1024).toFixed(1) + ' MB';
  }
  window.removeFile = function () {
    var fi = document.getElementById('video-file');
    if (fi) fi.value = '';
    var prev = document.getElementById('file-preview');
    if (prev) prev.classList.remove('active');
  };
})();
</script>

